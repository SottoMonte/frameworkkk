<?xml version="1.0" encoding="UTF-8"?>
<Window type="page" title="Alessandro Verdi | Portfolio" background="#0B0E14,#1a1c2c" font="sans">
    
    <!-- Navigation Bar -->
    <Navigation orientation="horizontal" alignment-content="between" padding="20px,40px" position="fixed" top="0" width="full" style="z-index: 50;" matter="glass-min">
        <Row align="center" spacing="10px">
            <Icon name="bi-terminal-fill" size="24px" color="#00D2FF" />
            <Text type="h4" font="bold" color="#FFFFFF">AV.dev</Text>
        </Row>
        <Row align="center" spacing="30px">
            <Action type="link" route="#about"><Text color="#BBBBBB" hover-color="#FFFFFF">About</Text></Action>
            <Action type="link" route="#skills"><Text color="#BBBBBB" hover-color="#FFFFFF">Skills</Text></Action>
            <Action type="link" route="#projects"><Text color="#BBBBBB" hover-color="#FFFFFF">Projects</Text></Action>
            <Action type="link" route="#contact" background="#00D2FF,#3a7bd5" padding="8px,20px" radius="full">
                <Text font="bold" color="#FFFFFF">Hire Me</Text>
            </Action>
        </Row>
    </Navigation>

    <Column width="full" padding="100px,20px,40px,20px" align="center" spacing="80px">
        
        <!-- Hero Section -->
        <Column id="hero" align="center" spacing="20px" padding="60px,0">
            <Container background="#00D2FF,#9D50BB" padding="2px" radius="full" width="160px" height="160px">
                <Media type="image" src="https://i.pravatar.cc/300?img=68" width="full" height="full" radius="full" />
            </Container>
            <Text type="h1" font="extrabold" size="64px" color="#FFFFFF" align="center">Alessandro Verdi</Text>
            <Text type="h2" font="bold" size="24px" color="#00D2FF" align="center">Full-Stack Architect &amp; Python Ninja</Text>
            <Text type="p" size="18px" color="#AAAAAA" width="600px" align="center">
                I build scalable distributed systems and beautiful user interfaces. 
                Passionate about clean code, performance, and modern web technologies.
            </Text>
            <Row spacing="20px" margin="20px,0">
                <Action type="button" background="#00D2FF,#3a7bd5" padding="12px,32px" radius="medium" shadow="large">
                    <Text font="bold" color="#FFFFFF">View Work</Text>
                </Action>
                <Action type="button" border="1px solid #333" background="transparent" padding="12px,32px" radius="medium">
                    <Text font="bold" color="#FFFFFF">Get in Touch</Text>
                </Action>
            </Row>
        </Column>

        <!-- Stats Row -->
        <Row width="full" max-width="1000px" justify="between" padding="40px" matter="glass" radius="large" border="1px solid #ffffff10">
            <Column align="center">
                <Text type="h3" font="bold" color="#00D2FF">8+</Text>
                <Text color="#888">Years Experience</Text>
            </Column>
            <Divider orientation="vertical" thickness="1px" color="#333" height="40px" />
            <Column align="center">
                <Text type="h3" font="bold" color="#00D2FF">50+</Text>
                <Text color="#888">Projects Completed</Text>
            </Column>
            <Divider orientation="vertical" thickness="1px" color="#333" height="40px" />
            <Column align="center">
                <Text type="h3" font="bold" color="#00D2FF">20+</Text>
                <Text color="#888">Happy Clients</Text>
            </Column>
        </Row>

        <!-- Skills Section -->
        <Column id="skills" width="full" max-width="1200px" spacing="40px">
            <Text type="h2" font="bold" size="32px" color="#FFFFFF">Technical Expertise</Text>
            <Grid class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-4" spacing="20px" width="full">
                <!-- Skill Card 1 -->
                <Column padding="30px" background="#ffffff05" radius="medium" border="1px solid #ffffff10" hover-background="#ffffff10">
                    <Icon name="bi-code-slash" size="32px" color="#00D2FF" margin="0,0,15px,0" />
                    <Text type="h4" font="bold" color="#FFFFFF">Backend</Text>
                    <Text color="#888" size="14px">Python, FastAPI, Django, PostgreSQL, Redis</Text>
                </Column>
                <!-- Skill Card 2 -->
                <Column padding="30px" background="#ffffff05" radius="medium" border="1px solid #ffffff10" hover-background="#ffffff10">
                    <Icon name="bi-layers" size="32px" color="#9D50BB" margin="0,0,15px,0" />
                    <Text type="h4" font="bold" color="#FFFFFF">Frontend</Text>
                    <Text color="#888" size="14px">React, Next.js, Tailwind CSS, TypeScript</Text>
                </Column>
                <!-- Skill Card 3 -->
                <Column padding="30px" background="#ffffff05" radius="medium" border="1px solid #ffffff10" hover-background="#ffffff10">
                    <Icon name="bi-cpu" size="32px" color="#FFD700" margin="0,0,15px,0" />
                    <Text type="h4" font="bold" color="#FFFFFF">Infrastructure</Text>
                    <Text color="#888" size="14px">Docker, Kubernetes, AWS, CI/CD, Terraform</Text>
                </Column>
                <!-- Skill Card 4 -->
                <Column padding="30px" background="#ffffff05" radius="medium" border="1px solid #ffffff10" hover-background="#ffffff10">
                    <Icon name="bi-graph-up" size="32px" color="#00FF7F" margin="0,0,15px,0" />
                    <Text type="h4" font="bold" color="#FFFFFF">Data Science</Text>
                    <Text color="#888" size="14px">Pandas, NumPy, Scikit-Learn, PyTorch</Text>
                </Column>
            </Grid>
        </Column>

        <!-- Projects Section -->
        <Column id="projects" width="full" max-width="1200px" spacing="40px">
            <Row justify="between" align="end">
                <Column spacing="10px">
                    <Text type="h2" font="bold" size="32px" color="#FFFFFF">Featured Projects</Text>
                    <Text color="#888">A selection of my recent work</Text>
                </Column>
                <Action type="link" route="/projects"><Text color="#00D2FF">View all projects &rarr;</Text></Action>
            </Row>
            
            <Grid class="grid-cols-1 md:grid-cols-2" spacing="30px" width="full">
                <!-- Project 1 -->
                <Column background="#161b22" radius="large" overflow="hidden" border="1px solid #ffffff10">
                    <Media type="image" src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&amp;fit=crop&amp;w=800&amp;q=80" width="full" height="250px" />
                    <Column padding="30px" spacing="15px">
                        <Text type="h4" font="bold" color="#FFFFFF">OmniPort Framework</Text>
                        <Text color="#AAA">A high-performance hexagonal architecture framework for modern web applications.</Text>
                        <Row spacing="10px">
                            <Container background="#00D2FF20" padding="4px,12px" radius="full"><Text size="12px" color="#00D2FF">Python</Text></Container>
                            <Container background="#9D50BB20" padding="4px,12px" radius="full"><Text size="12px" color="#9D50BB">FastAPI</Text></Container>
                        </Row>
                        <Action type="link" route="#" margin="10px,0,0,0"><Text font="bold" color="#FFFFFF">View Project ›</Text></Action>
                    </Column>
                </Column>
                <!-- Project 2 -->
                <Column background="#161b22" radius="large" overflow="hidden" border="1px solid #ffffff10">
                    <Media type="image" src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&amp;fit=crop&amp;w=800&amp;q=80" width="full" height="250px" />
                    <Column padding="30px" spacing="15px">
                        <Text type="h4" font="bold" color="#FFFFFF">Cloud Analytics Dashboard</Text>
                        <Text color="#AAA">Real-time data visualization platform for monitoring cloud infrastructure metrics.</Text>
                        <Row spacing="10px">
                            <Container background="#00FF7F20" padding="4px,12px" radius="full"><Text size="12px" color="#00FF7F">React</Text></Container>
                            <Container background="#FFD70020" padding="4px,12px" radius="full"><Text size="12px" color="#FFD700">AWS</Text></Container>
                        </Row>
                        <Action type="link" route="#" margin="10px,0,0,0"><Text font="bold" color="#FFFFFF">View Project ›</Text></Action>
                    </Column>
                </Column>
            </Grid>
        </Column>

        <!-- CTA Section -->
        <Column width="full" padding="80px,0" background="#00D2FF,#9D50BB" radius="large" align="center" spacing="30px">
            <Text type="h2" font="bold" size="40px" color="#FFFFFF" align="center">Ready to start your next project?</Text>
            <Text color="#FFFFFF" opacity="0.8" size="18px" width="500px" align="center">
                I'm currently available for freelance work and consulting. Let's build something amazing together.
            </Text>
            <Action type="button" background="#FFFFFF" padding="15px,40px" radius="full" shadow="max">
                <Text font="bold" color="#0B0E14">Get Started Now</Text>
            </Action>
        </Column>

        <!-- Footer -->
        <Divider width="full" thickness="1px" color="#ffffff10" />
        <Row width="full" justify="between" align="center" padding="0,0,40px,0">
            <Text color="#555">© 2026 Alessandro Verdi. All rights reserved.</Text>
            <Row spacing="20px">
                <Action type="link" route="https://github.com"><Icon name="bi-github" color="#555" hover-color="#FFFFFF" /></Action>
                <Action type="link" route="https://linkedin.com"><Icon name="bi-linkedin" color="#555" hover-color="#FFFFFF" /></Action>
                <Action type="link" route="https://twitter.com"><Icon name="bi-twitter" color="#555" hover-color="#FFFFFF" /></Action>
            </Row>
        </Row>

    </Column>

</Window>
