<Window type="page" title="YouTube Studio - Upload" background="#0f0f0f">
    <TopNav />
    <Row align="center" justify="center" height="full" padding="100px,0">
        <Column width="50%" max-width="800px" background="#272727" radius="16px" padding="32px" spacing="24px">
            <Row justify="between" align="center">
                <Text type="h1" color="white" font="bold" size="28px">Upload Video</Text>
                <Icon name="bi-cloud-arrow-up" size="32px" color="#568dff" />
            </Row>

            <Divider color="#3f3f3f" />

            <Column spacing="16px">
                <Column spacing="8px">
                    <Text color="#aaa" font="bold" size="14px">Title (required)</Text>
                    <Input type="text" placeholder="Add a title that describes your video" background="#1e1e1e" border="1px solid #3f3f3f" radius="8px" padding="12px" color="white" width="full" />
                </Column>

                <Column spacing="8px">
                    <Text color="#aaa" font="bold" size="14px">Description</Text>
                    <Input type="textarea" placeholder="Tell viewers about your video" background="#1e1e1e" border="1px solid #3f3f3f" radius="8px" padding="12px" color="white" width="full" height="150px" />
                </Column>

                <Row spacing="16px">
                    <Column width="full" spacing="8px">
                         <Text color="#aaa" font="bold" size="14px">Visibility</Text>
                         <Input type="select" background="#1e1e1e" border="1px solid #3f3f3f" radius="8px" padding="12px" color="white" width="full">
                             <Text value="public">Public</Text>
                             <Text value="unlisted">Unlisted</Text>
                             <Text value="private">Private</Text>
                         </Input>
                    </Column>
                    <Column width="full" spacing="8px">
                         <Text color="#aaa" font="bold" size="14px">Category</Text>
                         <Input type="select" background="#1e1e1e" border="1px solid #3f3f3f" radius="8px" padding="12px" color="white" width="full">
                             <Text value="gaming">Gaming</Text>
                             <Text value="music">Music</Text>
                             <Text value="tech">Technology</Text>
                             <Text value="education">Education</Text>
                         </Input>
                    </Column>
                </Row>
            </Column>

            <Divider color="#3f3f3f" />

            <Row justify="end" spacing="12px">
                <Action type="button" background="transparent" radius="full" padding="10px,24px">
                    <Text color="#568dff" font="bold">CANCEL</Text>
                </Action>
                <Action type="submit" background="#568dff" radius="full" padding="10px,32px">
                    <Text color="black" font="bold">UPLOAD</Text>
                </Action>
            </Row>
        </Column>
    </Row>
</Window>
