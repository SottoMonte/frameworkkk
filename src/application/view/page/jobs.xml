<Window type="page" title="Job Board - Find Your Next Career" background="#f8fafc" padding="0">
    <!-- Header/Navigation -->
    <Navigation background="#ffffff" border="0,0,1px,0" border-color="#e2e8f0" padding="16px,40px" width="full" position="sticky" top="0">
        <Row justify="between" align="center" width="full">
            <Row align="center">
                <Icon name="bi-briefcase-fill" size="24px" color="#3182ce" />
                <Text type="h2" font="extrabold" margin="0,0,0,10px" color="#1a202c" size="xl">CareerHub</Text>
            </Row>
            <Row spacing="24px" align="center">
                <Action type="link" src="/jobs">
                    <Text font="bold" color="#4a5568" size="sm">Find Jobs</Text>
                </Action>
                <Action type="link" src="/companies">
                    <Text font="bold" color="#4a5568" size="sm">Companies</Text>
                </Action>
                <Action type="link" src="/salaries">
                    <Text font="bold" color="#4a5568" size="sm">Salaries</Text>
                </Action>
                <Divider type="vertical" height="20px" margin="0,8px" thickness="1px" color="#e2e8f0" />
                <Action type="button" background="#3182ce" padding="10px,20px" radius="medium" shadow="min">
                    <Text color="#ffffff" font="bold" size="sm">Post a Job</Text>
                </Action>
            </Row>
        </Row>
    </Navigation>

    <!-- Hero Section -->
    <Column background="#3182ce,#2c5282" padding="80px,40px" align="center" width="full">
        <Text type="h1" font="extrabold" color="#ffffff" size="4xl" align="center">Find Your Dream Job Today</Text>
        <Text type="p" color="#ebf8ff" size="lg" margin="16px,0,40px,0" align="center">Thousands of jobs from the world's most promising startups and established companies.</Text>
        
        <!-- Search Bar -->
        <Container padding="12px" background="#ffffff/20" matter="glass" radius="large" width="full" max-width="800px">
            <Row spacing="12px" width="full">
                <Container background="#ffffff" radius="full" padding="0,20px" expand="1" height="56px" shadow="min">
                    <Row align="center" height="full">
                        <Icon name="bi-search" size="18px" color="#94a3b8" />
                        <Input type="text" placeholder="Job title, keywords, or company" width="full" padding="0,12px" border="0" font="bold" size="md" color="#1a202c" class="focus:outline-none bg-transparent" />
                    </Row>
                </Container>
                <Container background="#ffffff" radius="full" padding="0,20px" width="220px" height="56px" shadow="min">
                    <Row align="center" height="full">
                        <Icon name="bi-geo-alt" size="18px" color="#94a3b8" />
                        <Input type="text" placeholder="City or remote" width="full" padding="0,12px" border="0" font="bold" size="md" color="#1a202c" class="focus:outline-none bg-transparent" />
                    </Row>
                </Container>
                <Action type="submit" background="#2f855a" padding="0,32px" radius="medium" height="56px" shadow="medium">
                    <Text color="#ffffff" font="bold" size="md">Search Jobs</Text>
                </Action>
            </Row>
        </Container>
    </Column>

    <!-- Main Content Area -->
    <Container padding="48px,40px" width="full" max-width="1200px" align="center" margin="0,auto">
        <Row spacing="32px" width="full">
            <!-- Sidebar / Filters -->
            <Column width="300px" spacing="24px">
                <Column padding="24px" background="#ffffff" radius="large" shadow="min" border="1px solid #eef2f6" width="full">
                    <Text type="h4" font="bold" color="#2d3748" margin="0,0,16px,0">Job Type</Text>
                    <Row align="center" margin="0,0,12px,0">
                        <Input type="checkbox" name="full-time" />
                        <Text color="#4a5568" margin="0,0,0,10px">Full-time (1.2k)</Text>
                    </Row>
                    <Row align="center" margin="0,0,12px,0">
                        <Input type="checkbox" name="part-time" />
                        <Text color="#4a5568" margin="0,0,0,10px">Part-time (450)</Text>
                    </Row>
                    <Row align="center" margin="0,0,12px,0">
                        <Input type="checkbox" name="contract" />
                        <Text color="#4a5568" margin="0,0,0,10px">Contract (230)</Text>
                    </Row>
                    <Row align="center">
                        <Input type="checkbox" name="remote" />
                        <Text color="#4a5568" margin="0,0,0,10px">Remote (870)</Text>
                    </Row>

                    <Divider margin="24px,0" color="#edf2f7" />

                    <Text type="h4" font="bold" color="#2d3748" margin="0,0,16px,0">Salary Range</Text>
                    <Input type="range" min="0" max="200000" width="full" />
                    <Row justify="between" margin="8px,0,0,0">
                        <Text type="span" color="#718096" size="xs">$0</Text>
                        <Text type="span" color="#718096" size="xs">$200k+</Text>
                    </Row>
                </Column>

                <Column padding="24px" background="#2d3748" radius="large" shadow="medium" width="full">
                    <Text type="h4" font="bold" color="#ffffff" margin="0,0,12px,0">Get New Jobs</Text>
                    <Text type="p" color="#cbd5e0" size="sm" margin="0,0,16px,0">Sign up for personalized job alerts to your inbox.</Text>
                    <Input type="email" placeholder="Your email address" width="full" padding="10px,12px" radius="medium" background="#4a5568" border="0" color="#ffffff" />
                    <Action type="button" background="#3182ce" width="full" padding="10px,0" margin="16px,0,0,0" radius="medium">
                        <Text color="#ffffff" font="bold" size="sm">Subscribe Now</Text>
                    </Action>
                </Column>
            </Column>

            <!-- Listings / Form Section -->
            <Column expand="1" spacing="24px">
                <!-- Post Job Section (Hidden by default or shown on click, for demo I'll show it at the top of the feed) -->
                <PostJobForm />

                <Row justify="between" align="center" margin="16px,0,24px,0">
                    <Text type="h3" font="bold" color="#1a202c">Recent Postings (2,451)</Text>
                    <Row align="center">
                        <Text type="span" color="#718096" size="sm" margin="0,12px,0,0">Sort by:</Text>
                        <Input type="select" padding="6px,12px" radius="medium" background="#ffffff" border="1px solid #eef2f6" size="sm">
                            <Text value="newest">Newest first</Text>
                            <Text value="salary-desc">Salary: High to Low</Text>
                            <Text value="location">Closest location</Text>
                        </Input>
                    </Row>
                </Row>

                <!-- Job Listings -->
                <JobCard title="Senior Backend Developer" company="Supabase" location="Remote, Global" salary="$120k - $160k" posted="2 hours ago" type="Full-time" category="Engineering" />
                <JobCard title="Product Designer (UI/UX)" company="Airbnb" location="San Francisco, CA" salary="$140k - $190k" posted="5 hours ago" type="Full-time" category="Design" />
                <JobCard title="Senior DevOps Engineer" company="Vercel" location="Remote" salary="$130k - $180k" posted="1 day ago" type="Contract" category="Engineering" />
                <JobCard title="Marketing Lead" company="Stripe" location="New York, NY" salary="$100k - $140k" posted="1 day ago" type="Full-time" category="Marketing" />
                <JobCard title="Fullstack Engineer" company="Slack" location="Vancouver, BC" salary="$110k - $150k" posted="2 days ago" type="Freelance" category="Engineering" />
                <JobCard title="Growth Product Manager" company="Discord" location="San Francisco, CA" salary="$130k - $170k" posted="2 days ago" type="Full-time" category="Product" />

                <!-- Pagination -->
                <Row justify="center" margin="32px,0,0,0" spacing="8px">
                    <Action type="button" background="#ffffff" border="1px solid #e2e8f0" padding="8px,16px" radius="medium">
                        <Text color="#4a5568" font="bold">Previous</Text>
                    </Action>
                    <Container background="#3182ce" padding="8px,16px" radius="medium">
                        <Text color="#ffffff" font="bold">1</Text>
                    </Container>
                    <Container background="#ffffff" border="1px solid #e2e8f0" padding="8px,16px" radius="medium">
                        <Text color="#4a5568" font="bold">2</Text>
                    </Container>
                    <Container background="#ffffff" border="1px solid #e2e8f0" padding="8px,16px" radius="medium">
                        <Text color="#4a5568" font="bold">3</Text>
                    </Container>
                    <Action type="button" background="#ffffff" border="1px solid #e2e8f0" padding="8px,16px" radius="medium">
                        <Text color="#4a5568" font="bold">Next</Text>
                    </Action>
                </Row>
            </Column>
        </Row>
    </Container>

    <!-- Footer -->
    <Column background="#1a202c" padding="64px,40px" width="full" margin="80px,0,0,0">
        <Row justify="between" width="full" max-width="1200px" margin="0,auto">
            <Column width="300px">
                <Row align="center">
                    <Icon name="bi-briefcase-fill" size="24px" color="#3182ce" />
                    <Text type="h3" font="extrabold" color="#ffffff" margin="0,0,0,10px">CareerHub</Text>
                </Row>
                <Text type="p" color="#a0aec0" size="sm" margin="16px,0,24px,0">The leading job board for tech professionals around the world. Trusted by 2,000+ companies.</Text>
                <Row spacing="16px">
                    <Icon name="bi-twitter" size="20px" color="#cbd5e0" />
                    <Icon name="bi-linkedin" size="20px" color="#cbd5e0" />
                    <Icon name="bi-github" size="20px" color="#cbd5e0" />
                </Row>
            </Column>
            <Row spacing="64px">
                <Column>
                    <Text font="bold" color="#ffffff" margin="0,0,16px,0">For Candidates</Text>
                    <Text color="#a0aec0" margin="0,0,8px,0" size="sm">Browse Jobs</Text>
                    <Text color="#a0aec0" margin="0,0,8px,0" size="sm">Job Alerts</Text>
                    <Text color="#a0aec0" margin="0,0,8px,0" size="sm">Career Advice</Text>
                </Column>
                <Column>
                    <Text font="bold" color="#ffffff" margin="0,0,16px,0">For Employers</Text>
                    <Text color="#a0aec0" margin="0,0,8px,0" size="sm">Post a Job</Text>
                    <Text color="#a0aec0" margin="0,0,8px,0" size="sm">Hiring Solutions</Text>
                    <Text color="#a0aec0" margin="0,0,8px,0" size="sm">Pricing</Text>
                </Column>
                <Column>
                    <Text font="bold" color="#ffffff" margin="0,0,16px,0">Company</Text>
                    <Text color="#a0aec0" margin="0,0,8px,0" size="sm">About Us</Text>
                    <Text color="#a0aec0" margin="0,0,8px,0" size="sm">Contact</Text>
                    <Text color="#a0aec0" margin="0,0,8px,0" size="sm">Privacy Policy</Text>
                </Column>
            </Row>
        </Row>
        <Divider margin="48px,0,32px,0" color="#2d3748" />
        <Text align="center" color="#718096" size="xs">© 2026 CareerHub Inc. All rights reserved.</Text>
    </Column>
</Window>
