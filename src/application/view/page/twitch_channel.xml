{% extends "twitch_layout.xml" %}

{% block content %}
<Row width="full" height="full" spacing="0">
    <!-- Stream Content (Left side) -->
    <Column flex-grow="1" height="full" overflow="auto" background="#0e0e10" padding="20px">
        <!-- Main Player -->
        <Container width="full" height="60vh" background="#000000" radius="none" position="relative" overflow="hidden">
            <Column align="center" justify="center" height="full">
                <Icon name="bi-play-fill" size="96px" color="#9146ff" />
                <Text type="h5" font="bold" color="#ffffff">Live Stream Content</Text>
            </Column>
            
            <!-- Controls (Simulated Overlay) -->
            <Row position="absolute" bottom="0" left="0" width="full" background="#00000088" padding="12px,24px" justify="between" align="center" matter="glass-min">
                <Row align="center" spacing="20px">
                    <Icon name="bi-play-fill" size="24px" color="#ffffff" pointer="pointer" />
                    <Icon name="bi-volume-up-fill" size="24px" color="#ffffff" pointer="pointer" />
                    <Text color="#ffffff" size="13px" font="bold" font-mono="true">00:00 / 00:00</Text>
                </Row>
                <Row align="center" spacing="20px">
                    <Icon name="bi-gear-fill" size="20px" color="#ffffff" pointer="pointer" />
                    <Icon name="bi-aspect-ratio" size="20px" color="#ffffff" pointer="pointer" />
                    <Icon name="bi-fullscreen" size="20px" color="#ffffff" pointer="pointer" />
                </Row>
            </Row>
        </Container>

        <!-- Stream Info Bar -->
        <Row width="full" padding="20px,0" spacing="20px" align="start">
            <Container width="64px" height="64px" background="#9146ff" radius="full" align="center" justify="center" border="4px solid #9146ff">
                <Text font="bold" size="20px" color="#ffffff">XQ</Text>
                <Container position="absolute" bottom="0" background="#eb0400" padding="1px,6px" radius="small" border="2px solid #0e0e10">
                    <Text size="10px" font="bold" color="#ffffff">LIVE</Text>
                </Container>
            </Container>
            
            <Column flex-grow="1" spacing="4px">
                <Text type="h4" font="bold" color="#ffffff">THE JUICER IS BACK | REACTIONS &amp; DRAMA | VALORANT LATER</Text>
                <Row spacing="12px" align="center">
                    <Text type="h6" font="bold" color="#ffffff" hover-color="#9146ff">xQc</Text>
                    <Icon name="bi-patch-check-fill" size="14px" color="#9146ff" />
                    <Text type="p" color="#9146ff" font="bold" size="14px">Just Chatting</Text>
                </Row>
                <Row spacing="12px" align="center">
                    <Row spacing="6px" align="center">
                        <Icon name="bi-person" size="14px" color="#eb0400" />
                        <Text color="#eb0400" font="bold" size="13px">54.2K viewers</Text>
                    </Row>
                    <Text color="#adadb8" size="13px">2:45:12 live duration</Text>
                </Row>
            </Column>
            
            <Row spacing="12px">
                <Action type="button" background="#9146ff" radius="medium" padding="8px,16px" hover-background="#772ce8">
                    <Row align="center" spacing="8px">
                        <Icon name="bi-heart" size="16px" color="#ffffff" />
                        <Text font="bold" color="#ffffff" size="14px">Follow</Text>
                    </Row>
                </Action>
                <Action type="button" background="#ffffff1a" radius="medium" padding="8px,12px" hover-background="#ffffff26">
                    <Icon name="bi-star" size="16px" color="#ffffff" />
                </Action>
            </Row>
        </Row>
        
        <!-- About Section -->
        <Container width="full" background="#18181b" padding="24px" radius="large" margin="20px,0">
            <Column spacing="16px">
                <Text type="h5" font="bold" color="#ffffff">About xQc</Text>
                <Row spacing="24px">
                    <Column spacing="4px">
                        <Text font="bold" color="#ffffff" size="16px">11.4M</Text>
                        <Text color="#adadb8" size="12px">Followers</Text>
                    </Column>
                    <Column spacing="4px">
                        <Text font="bold" color="#ffffff" size="16px">Variety</Text>
                        <Text color="#adadb8" size="12px">Category</Text>
                    </Column>
                </Row>
                <Text color="#efeff1" size="14px" line-height="1.6">
                    Felix 'xQc' Lengyel is a Canadian Twitch streamer, internet personality, and former professional Overwatch player. He is best known for his variety content and high-energy broadcasts that cater to millions of viewers worldwide.
                </Text>
            </Column>
        </Container>
    </Column>

    <!-- Chat (Right side) -->
    <Column width="340px" height="full" background="#18181b" style="border-left: 1px solid #1f1f23;">
        <Row width="full" height="50px" padding="0,16px" align="center" justify="between" border-bottom="1px solid #1f1f23">
            <Icon name="bi-arrow-right" size="18px" color="#ffffff" pointer="pointer" />
            <Text type="h6" font="bold" color="#ffffff" size="13px" uppercase="true">Stream Chat</Text>
            <Icon name="bi-people" size="18px" color="#ffffff" pointer="pointer" />
        </Row>
        
        <!-- Chat History -->
        <Column flex-grow="1" overflow="auto" padding="16px" spacing="12px">
            <Row align="start" spacing="8px">
                 <Text color="#efeff1" size="13px"><Text font="bold" color="#568dff">Poki_Fan:</Text> LUL what is he doing??</Text>
            </Row>
             <Row align="start" spacing="8px">
                 <Text color="#efeff1" size="13px"><Text font="bold" color="#eb0400">Moderator_Bot:</Text> Welcome to the stream! Check out the rules.</Text>
            </Row>
             <Row align="start" spacing="8px">
                 <Text color="#efeff1" size="13px"><Text font="bold" color="#9146ff">Shround_Viewer:</Text> HE'S INSANE O_O</Text>
            </Row>
             <Row align="start" spacing="8px">
                 <Text color="#efeff1" size="13px"><Text font="bold" color="#77c8e9">User_123:</Text> KEKW PogChamp</Text>
            </Row>
             <Row align="start" spacing="8px">
                 <Text color="#efeff1" size="13px"><Text font="bold" color="#9acd32">EcoFriendly:</Text> did he just win? no way</Text>
            </Row>
             <Row align="start" spacing="8px">
                 <Text color="#efeff1" size="13px"><Text font="bold" color="#ff69b4">Hype_Train:</Text> hype hype hype hype!</Text>
            </Row>
        </Column>
        
        <!-- Input Section -->
        <Column width="full" padding="16px" spacing="12px" background="#18181b">
             <Container width="full" background="#18181b" radius="medium" border="1px solid #35353b" padding="0,8px">
                 <Input width="full" type="text" placeholder="Send a message" background="transparent" color="#ffffff" height="40px" border="none" />
             </Container>
             <Row justify="between" align="center">
                 <Row spacing="8px">
                    <Icon name="bi-emoji-smile" size="18px" color="#ffffff" pointer="pointer" />
                    <Icon name="bi-stars" size="18px" color="#ffffff" pointer="pointer" />
                 </Row>
                 <Action type="button" background="#9146ff" radius="medium" padding="6px,12px" hover-background="#772ce8">
                    <Text font="bold" color="#ffffff" size="13px">Chat</Text>
                 </Action>
             </Row>
        </Column>
    </Column>
</Row>
{% endblock %}
