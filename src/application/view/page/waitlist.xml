<?xml version="1.0" encoding="UTF-8"?>
<Window type="page" title="Join the Waitlist | Next-Gen Product" background="#050505,#121212" font="sans">
    
    <!-- Navigation Bar (Floating Pill) -->
    <Navigation width="full" position="fixed" top="20px" align="center" style="z-index: 100;">
        <Row background="#121212/80" matter="glass" padding="10px,25px" radius="full" border="1px solid #ffffff10" shadow="max" align="center" spacing="40px">
            <Row align="center" spacing="10px">
                <Icon name="bi-hexagon-fill" size="20px" color="#FF3E00" />
                <Text type="h5" font="bold" color="#FFFFFF" spacing="2px">NEON</Text>
            </Row>
            
            <Row align="center" spacing="20px">
                <Action type="link" route="/#features"><Text size="14px" color="#888" hover-color="#FFFFFF">Features</Text></Action>
                <Action type="link" route="/#roadmap"><Text size="14px" color="#888" hover-color="#FFFFFF">Roadmap</Text></Action>
                <Action type="link" route="/#pricing"><Text size="14px" color="#888" hover-color="#FFFFFF">Pricing</Text></Action>
            </Row>

            <Action type="link" route="/" background="#FF3E00" padding="8px,20px" radius="full">
                <Text font="bold" size="14px" color="#FFFFFF">Early Access</Text>
            </Action>
        </Row>
    </Navigation>

    <Column width="full" padding="120px,20px,80px,20px" align="center" spacing="60px">
        
        <!-- Hero Section -->
        <Column align="center" spacing="24px" max-width="800px">
            <Container background="#FF3E0020" padding="8px,16px" radius="full" border="1px solid #FF3E0040">
                <Text size="14px" color="#FF3E00" font="bold" uppercase="true">Coming Soon</Text>
            </Container>
            <Text type="h1" font="extrabold" size="56px" color="#FFFFFF" align="center" style="line-height: 1.1;">
                Revolutionizing the way you build <Text color="#FF3E00">Digital Experiences</Text>
            </Text>
            <Text type="p" size="20px" color="#AAAAAA" align="center">
                We are building the most advanced platform for creators and developers. 
                Answer a few questions to help us shape the future and get early access.
            </Text>
        </Column>

        <!-- Survey & Signup Card -->
        <Column width="full" max-width="600px" background="#161616" padding="40px" radius="large" border="1px solid #ffffff10" shadow="max" spacing="32px">
            
            <Text type="h3" font="bold" color="#FFFFFF">Quick Survey</Text>
            
            <!-- Question 1: Role -->
            <Column spacing="12px">
                <Text color="#EEEEEE" font="bold">1. Qual è il tuo ruolo principale?</Text>
                <Grid class="grid-cols-2" spacing="12px">
                    <Action type="button" border="1px solid #333" background="#ffffff05" padding="12px" radius="medium" align="center">
                        <Row align="center" spacing="8px"><Icon name="bi-code" color="#FF3E00" /><Text color="#AAA">Developer</Text></Row>
                    </Action>
                    <Action type="button" border="1px solid #333" background="transparent" padding="12px" radius="medium" align="center">
                        <Row align="center" spacing="8px"><Icon name="bi-brush" color="#888" /><Text color="#888">Designer</Text></Row>
                    </Action>
                </Grid>
            </Column>

            <!-- Question 2: Stack -->
            <Column spacing="12px">
                <Text color="#EEEEEE" font="bold">2. Che stack utilizzi per lo sviluppo?</Text>
                <Row spacing="10px" overflow="auto" padding="5px,0">
                    <Action type="button" border="1px solid #333" background="transparent" padding="8px,16px" radius="full"><Text size="12px" color="#888">Python / FastAPI</Text></Action>
                    <Action type="button" border="1px solid #333" background="transparent" padding="8px,16px" radius="full"><Text size="12px" color="#888">Node.js / Next.js</Text></Action>
                    <Action type="button" border="1px solid #333" background="transparent" padding="8px,16px" radius="full"><Text size="12px" color="#888">Go / Rust</Text></Action>
                    <Action type="button" border="1px solid #333" background="transparent" padding="8px,16px" radius="full"><Text size="12px" color="#888">PHP / Laravel</Text></Action>
                </Row>
            </Column>

            <!-- Question 3: Management/Infrastructure -->
            <Column spacing="12px">
                <Text color="#EEEEEE" font="bold">3. Come gestisci le tue applicazioni?</Text>
                <Grid class="grid-cols-1 md:grid-cols-3" spacing="10px">
                    <Action type="button" border="1px solid #333" background="transparent" padding="12px" radius="medium">
                         <Column align="center" spacing="4px">
                            <Icon name="bi-cloud-check" size="20px" color="#00D2FF" />
                            <Text size="11px" color="#AAA">Managed Cloud</Text>
                         </Column>
                    </Action>
                    <Action type="button" border="1px solid #333" background="transparent" padding="12px" radius="medium">
                         <Column align="center" spacing="4px">
                            <Icon name="bi-box-seam" size="20px" color="#9D50BB" />
                            <Text size="11px" color="#AAA">Self-Hosted / K8s</Text>
                         </Column>
                    </Action>
                    <Action type="button" border="1px solid #333" background="transparent" padding="12px" radius="medium">
                         <Column align="center" spacing="4px">
                            <Icon name="bi-infinity" size="20px" color="#FFD700" />
                            <Text size="11px" color="#AAA">Serverless / Edge</Text>
                         </Column>
                    </Action>
                </Grid>
            </Column>

            <!-- Question 4: Primary Need -->
            <Column spacing="12px">
                <Text color="#EEEEEE" font="bold">4. Qual è la tua priorità principale?</Text>
                <Input type="select" name="priority" background="#000000" border="1px solid #333" padding="12px" radius="medium" color="#FFFFFF" width="full">
                    <Text>Scalabilità e Performance</Text>
                    <Text>Sicurezza e Compliance</Text>
                    <Text>Velocità di Sviluppo (DX)</Text>
                    <Text>Ottimizzazione dei Costi</Text>
                </Input>
            </Column>

            <!-- Question 5: Comments -->
            <Column spacing="12px">
                <Text color="#EEEEEE" font="bold">5. Altre note o tool preferiti?</Text>
                <Input type="text" name="interest" placeholder="es. Docker, Terraform, Prometheus..." background="#000000" border="1px solid #333" padding="12px" radius="medium" color="#FFFFFF" width="full" />
            </Column>

            <Divider thickness="1px" color="#ffffff10" />

            <!-- Waitlist Signup -->
            <Column spacing="16px">
                <Text type="h3" font="bold" color="#FFFFFF">Join the Waitlist</Text>
                <Text color="#888" size="14px">Get notified when we launch and secure your early bird discount.</Text>
                <Row spacing="10px" width="full" align="center">
                    <Input type="email" name="email" placeholder="enter your email address" background="#000000" border="1px solid #333" padding="12px,20px" radius="medium" color="#FFFFFF" expand="true" />
                    <Action type="button" background="#FF3E00" padding="12px,24px" radius="medium" shadow="large">
                        <Text font="bold" color="#FFFFFF">Subscribe</Text>
                    </Action>
                </Row>
            </Column>

        </Column>

        <!-- Social Proof / Features -->
        <Row spacing="40px" align="center">
            <Row align="center" spacing="8px">
                <Icon name="bi-shield-check" color="#FF3E00" size="20px" />
                <Text color="#666" size="14px">Secure &amp; Private</Text>
            </Row>
            <Row align="center" spacing="8px">
                <Icon name="bi-lightning-charge" color="#FF3E00" size="20px" />
                <Text color="#666" size="14px">Instant Access</Text>
            </Row>
            <Row align="center" spacing="8px">
                <Icon name="bi-award" color="#FF3E00" size="20px" />
                <Text color="#666" size="14px">Early Adopter Badge</Text>
            </Row>
        </Row>

    </Column>

    <!-- Footer -->
    <Column width="full" padding="40px" align="center" background="#0a0a0a">
        <Text color="#444" size="12px">© 2026 NEON Technologies. Built with OmniPort.</Text>
    </Column>

</Window>
