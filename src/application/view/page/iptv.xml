<Window type="page" title="OlympoTV Premium" background="#020617" pointer="default">
    <Row width="full" height="full">
        <!-- Sidebar - Deep Midnight -->
        <Column width="260px" height="full" background="#06080F" padding="40px,20px" spacing="30px" class="hidden md:flex border-r border-[#1E293B]/40" matter="glass-min">
            <Row align="center" spacing="12px" margin="0,0,20px,0">
                <Container width="40px" height="40px" radius="medium" background="#38BDF8,#818CF8" align="center" justify="center" shadow="medium">
                    <Icon name="bi-play-circle-fill" size="22px" color="#FFFFFF" />
                </Container>
                <Text type="h2" font="black" color="#FFFFFF" size="22px" class="tracking-tighter">OlympoTV</Text>
            </Row>

            <Column spacing="8px">
                <Text type="p" color="#475569" font="bold" uppercase="true" size="10px" margin="0,0,10px,5px" class="tracking-widest">Menu</Text>
                <Action type="link" padding="10px,15px" radius="medium" background="#38BDF8" class="shadow-lg shadow-sky-500/20">
                    <Row align="center" spacing="12px" width="full">
                        <Icon name="bi-compass-fill" color="#FFFFFF" />
                        <Text color="#FFFFFF" font="bold" size="14px">Esplora</Text>
                    </Row>
                </Action>
                <Action type="link" padding="10px,15px" radius="medium" background="transparent" class="hover:bg-[#1E293B]/40 transition-all">
                    <Row align="center" spacing="12px" width="full">
                        <Icon name="bi-film" color="#64748B" />
                        <Text color="#94A3B8" size="14px">Film</Text>
                    </Row>
                </Action>
                <Action type="link" padding="10px,15px" radius="medium" background="transparent" class="hover:bg-[#1E293B]/40 transition-all">
                    <Row align="center" spacing="12px" width="full">
                        <Icon name="bi-tv-fill" color="#64748B" />
                        <Text color="#94A3B8" size="14px">Serie TV</Text>
                    </Row>
                </Action>
                <Action type="link" padding="10px,15px" radius="medium" background="transparent" class="hover:bg-[#1E293B]/40 transition-all">
                    <Row align="center" spacing="12px" width="full">
                        <Icon name="bi-broadcast-pin" color="#64748B" />
                        <Text color="#94A3B8" size="14px">Live TV</Text>
                    </Row>
                </Action>
            </Column>

            <Column spacing="8px">
                <Text type="p" color="#475569" font="bold" uppercase="true" size="10px" margin="0,0,10px,5px" class="tracking-widest">Categorie</Text>
                <Action type="link" background="transparent" padding="8px,15px" class="hover:text-white group">
                    <Row align="center" spacing="12px">
                        <Container width="6px" height="6px" radius="full" background="#818CF8" />
                        <Text color="#64748B" size="14px" class="group-hover:text-slate-200">Azione</Text>
                    </Row>
                </Action>
                <Action type="link" background="transparent" padding="8px,15px" class="hover:text-white group">
                    <Row align="center" spacing="12px">
                        <Container width="6px" height="6px" radius="full" background="#38BDF8" />
                        <Text color="#64748B" size="14px" class="group-hover:text-slate-200">Cyberpunk</Text>
                    </Row>
                </Action>
                <Action type="link" background="transparent" padding="8px,15px" class="hover:text-white group">
                    <Row align="center" spacing="12px">
                        <Container width="6px" height="6px" radius="full" background="#C084FC" />
                        <Text color="#64748B" size="14px" class="group-hover:text-slate-200">Sci-Fi</Text>
                    </Row>
                </Action>
            </Column>

            <Column expand="true" justify="end">
                <Container background="linear-gradient(135deg, #1E293B, #0F172A)" padding="20px" radius="large" class="border border-[#38BDF8]/20 shadow-xl shadow-cyan-500/5">
                    <Column spacing="12px">
                        <Icon name="bi-award-fill" color="#38BDF8" size="24px" />
                        <Text color="#FFFFFF" font="bold" size="14px">Passa a Premium</Text>
                        <Text color="#94A3B8" size="12px">Contenuti esclusivi in 4K HDR.</Text>
                        <Action type="button" background="#FFFFFF" padding="10px" radius="medium" margin="5px,0,0,0" class="hover:scale-105 transition-transform">
                            <Text color="#020617" font="bold" size="12px">Upgrade</Text>
                        </Action>
                    </Column>
                </Container>
            </Column>
        </Column>

        <!-- Main Content Area -->
        <Column expand="true" height="full" padding="30px,40px" overflow="auto" class="bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-[#0F172A] via-[#020617] to-[#020617]">
            <!-- Responsive Top Bar -->
            <Row width="full" justify="between" align="center" margin="0,0,30px,0">
                <Row align="center" spacing="20px" expand="true">
                    <Action type="button" background="#1E293B" padding="10px" radius="medium" class="md:hidden">
                        <Icon name="bi-list" color="#FFFFFF" />
                    </Action>
                    <Row background="#000000/30" padding="12px,24px" radius="full" class="hidden sm:flex border border-[#1E293B]/50" width="450px" align="center" spacing="15px" matter="glass-min">
                        <Icon name="bi-search" color="#64748B" size="16px" />
                        <Text type="p" color="#64748B" size="14px">Cerca tra migliaia di titoli...</Text>
                    </Row>
                </Row>
                
                <Row align="center" spacing="20px">
                    <Action type="button" background="transparent" padding="8px" radius="full" class="hover:bg-[#1E293B]/40 relative">
                        <Icon name="bi-bell" color="#FFFFFF" size="20px" />
                        <Container width="8px" height="8px" background="#EF4444" radius="full" class="absolute top-1 right-1 border border-[#020617]" />
                    </Action>
                    <Row background="#1E293B/30" padding="4px,12px,4px,4px" radius="full" align="center" spacing="12px" class="border border-[#1E293B]/50" matter="glass-min">
                        <Container width="34px" height="34px" radius="full" background="linear-gradient(to bottom, #38BDF8, #818CF8)" align="center" justify="center">
                            <Icon name="bi-person-fill" color="#FFFFFF" size="18px" />
                        </Container>
                        <Text color="#FFFFFF" font="bold" size="14px" class="hidden lg:block">Premium User</Text>
                    </Row>
                </Row>
            </Row>

            <!-- Hero Cinematic Banner -->
            <Container width="full" height="450px" radius="large" margin="0,0,60px,0" class="relative group overflow-hidden border border-[#1E293B]/50 shadow-2xl">
                <!-- Richer Gradient Background -->
                <Container width="full" height="full" class="absolute inset-0 bg-[linear-gradient(90deg,#020617_20%,transparent_100%),radial-gradient(at_top_right,#1E1B4B_0%,#020617_100%)]">
                    <SVG width="full" height="full" class="opacity-40">
                         <defs>
                            <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                                <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#1E293B" stroke-width="0.5"/>
                            </pattern>
                        </defs>
                        <rect width="full" height="full" fill="url(#grid)" />
                    </SVG>
                </Container>

                <Column height="full" justify="center" spacing="25px" padding="0,60px" class="relative z-10">
                    <Row spacing="12px" align="center">
                        <Container background="#38BDF8" padding="4px,12px" radius="full">
                            <Text color="#020617" font="black" size="10px" class="tracking-widest">TOP 10</Text>
                        </Container>
                        <Text color="#38BDF8" font="bold" size="12px" uppercase="true" class="tracking-widest">In arrivo venerdì</Text>
                    </Row>
                    <Column spacing="5px">
                        <Text type="h1" font="black" color="#FFFFFF" size="64px" class="leading-none tracking-tighter drop-shadow-2xl">Blade Runner: Black Lotus</Text>
                        <Text type="p" color="#38BDF8" font="bold" size="18px">Serie Originale Olympo</Text>
                    </Column>
                    <Text type="p" color="#94A3B8" width="500px" size="16px" class="leading-relaxed opacity-90">
                        Los Angeles, 2032. Una giovane donna con capacit&amp;agrave; fisiche sovrumane si sveglia senza memoria dei suoi creatori. L'unica traccia? Un tatuaggio di loto nero.
                    </Text>
                    <Row spacing="20px" margin="10px,0,0,0">
                        <Action type="button" background="#FFFFFF" padding="16px,40px" radius="large" class="hover:bg-[#CBD5E1] transition-colors shadow-lg shadow-white/10">
                            <Row align="center" spacing="12px">
                                <Icon name="bi-play-fill" color="#020617" size="24px" />
                                <Text color="#020617" font="black" size="16px">GUARDA ORA</Text>
                            </Row>
                        </Action>
                        <Action type="button" background="#FFFFFF/10" padding="16px,32px" radius="large" matter="glass" class="border border-white/20 hover:bg-white/20 transition-all">
                            <Row align="center" spacing="12px">
                                <Icon name="bi-plus-lg" color="#FFFFFF" />
                                <Text color="#FFFFFF" font="bold" size="16px">LISTA</Text>
                            </Row>
                        </Action>
                    </Row>
                </Column>
            </Container>

            <!-- Catalog Sub-navigation -->
            <Row spacing="30px" margin="0,0,40px,0" class="border-b border-[#1E293B]/60 pb-4">
                <Action type="link" background="transparent" class="border-b-2 border-cyan-500 pb-4">
                    <Text color="#FFFFFF" font="bold">Tendenze</Text>
                </Action>
                <Action type="link" background="transparent" class="hover:text-white text-slate-500 pb-4">
                    <Text color="#475569" font="bold">Nuove Uscite</Text>
                </Action>
                <Action type="link" background="transparent" class="hover:text-white text-slate-500 pb-4">
                    <Text color="#475569" font="bold">I Pi&amp;ugrave; Visti</Text>
                </Action>
            </Row>

            <!-- Grid Sections -->
            <Column spacing="60px">
                <!-- Trending Grid -->
                <Column spacing="25px">
                    <Row justify="between" align="center">
                        <Row align="center" spacing="15px">
                            <Container width="6px" height="26px" background="linear-gradient(#38BDF8, #818CF8)" radius="full" />
                            <Text type="h3" color="#FFFFFF" font="black" size="26px" class="tracking-tight">Pi&amp;ugrave; Popolari su Olympo</Text>
                        </Row>
                        <Action type="link" class="bg-[#1E293B]/40 px-4 py-2 radius-full border border-[#1E293B] hover:bg-[#1E293B]/60 transition-all">
                            <Text color="#38BDF8" font="bold" size="12px">Vedi Tutto</Text>
                        </Action>
                    </Row>
                    
                    <Grid width="full" spacing="30px" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                        <!-- Card 1 -->
                        <Column spacing="18px">
                            <Container width="full" radius="large" background="linear-gradient(45deg, #0F172A, #1E293B)" shadow="large" class="group aspect-video relative overflow-hidden border border-[#1E293B]/50 hover:border-[#38BDF8]/50 transition-all duration-500">
                                <Column height="full" width="full" justify="center" align="center" class="bg-slate-900/40">
                                     <Icon name="bi-film" color="#1E293B" size="56px" />
                                </Column>
                                <!-- Floating UI on Card -->
                                <Container width="full" height="full" class="absolute inset-0 bg-[#020617]/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" align="center" justify="center">
                                     <Container width="60px" height="60px" radius="full" background="#FFFFFF" align="center" justify="center">
                                         <Icon name="bi-play-fill" color="#020617" size="32px" />
                                     </Container>
                                </Container>
                                <Container background="#38BDF8" padding="4px,10px" radius="small" class="absolute top-4 right-4">
                                    <Text color="#020617" font="bold" size="10px">NEW</Text>
                                </Container>
                            </Container>
                            <Row justify="between" align="start" padding="0,5px">
                                <Column spacing="4px">
                                    <Text type="p" color="#FFFFFF" font="bold" size="18px">Neon Horizons</Text>
                                    <Text type="p" color="#64748B" size="13px">2024 • Fantascienza • 4K</Text>
                                </Column>
                                <Icon name="bi-plus-circle" color="#64748B" size="18px" />
                            </Row>
                        </Column>

                        <!-- Card 2 -->
                        <Column spacing="18px">
                            <Container width="full" radius="large" background="linear-gradient(45deg, #312E81, #1E1B4B)" shadow="large" class="group aspect-video relative overflow-hidden border border-[#1E293B]/50 hover:border-[#38BDF8]/50 transition-all duration-500">
                                <Column height="full" width="full" justify="center" align="center" class="bg-indigo-950/40">
                                     <Icon name="bi-stars" color="#1E293B" size="56px" />
                                </Column>
                                <Container width="full" height="full" class="absolute inset-0 bg-[#020617]/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" align="center" justify="center">
                                     <Container width="60px" height="60px" radius="full" background="#FFFFFF" align="center" justify="center">
                                         <Icon name="bi-play-fill" color="#020617" size="32px" />
                                     </Container>
                                </Container>
                            </Container>
                            <Row justify="between" align="start" padding="0,5px">
                                <Column spacing="4px">
                                    <Text type="p" color="#FFFFFF" font="bold" size="18px">The Void Abyss</Text>
                                    <Text type="p" color="#64748B" size="13px">2023 • Thriller Psicologico</Text>
                                </Column>
                                <Icon name="bi-plus-circle" color="#64748B" size="18px" />
                            </Row>
                        </Column>

                        <!-- Card 3 -->
                        <Column spacing="18px">
                            <Container width="full" radius="large" background="linear-gradient(45deg, #1E1B4B, #0F172A)" shadow="large" class="group aspect-video relative overflow-hidden border border-[#1E293B]/50 hover:border-[#38BDF8]/50 transition-all duration-500">
                                <Column height="full" width="full" justify="center" align="center" class="bg-slate-900/40">
                                     <Icon name="bi-camera-reels-fill" color="#1E293B" size="56px" />
                                </Column>
                                <Container width="full" height="full" class="absolute inset-0 bg-[#020617]/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" align="center" justify="center">
                                     <Container width="60px" height="60px" radius="full" background="#FFFFFF" align="center" justify="center">
                                         <Icon name="bi-play-fill" color="#020617" size="32px" />
                                     </Container>
                                </Container>
                            </Container>
                            <Row justify="between" align="start" padding="0,5px">
                                <Column spacing="4px">
                                    <Text type="p" color="#FFFFFF" font="bold" size="18px">Cyberia 2077</Text>
                                    <Text type="p" color="#64748B" size="13px">2024 • Azione • UHD</Text>
                                </Column>
                                <Icon name="bi-plus-circle" color="#64748B" size="18px" />
                            </Row>
                        </Column>
                    </Grid>
                </Column>

                <!-- Footer Info -->
                <Row width="full" justify="center" padding="40px,0">
                    <Text color="#475569" size="12px">© 2026 Olympo Digital Entertainment • Tutti i diritti riservati</Text>
                </Row>
            </Column>
        </Column>
    </Row>
</Window>
