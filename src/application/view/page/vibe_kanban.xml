<Window type="page" title="Supabase Vibe Workspace" background="#171717" padding="20px">
    <!-- Top Header (Supabase Style) -->
    <Row justify="between" align="center" margin="0,0,25px,0" padding="12px,24px" background="#1c1c1c" radius="medium" border="1px solid #2e2e2e">
        <Row align="center" spacing="15px">
             <Container background="#3ecf8e" width="32px" height="32px" radius="small">
                <Icon name="bi-lightning-charge-fill" color="#171717" size="18px" />
             </Container>
             <Column>
                <Text type="h1" font="bold" color="#FFF" size="20px">Omni<Text color="#3ecf8e">Base</Text></Text>
                <Text type="p" color="#666" size="10px">v1.2.4 • <Text color="#3ecf8e">Online</Text></Text>
             </Column>
        </Row>
        <Row spacing="12px">
            <Action type="button" background="#232323" radius="small" padding="6px,16px" border="1px solid #2e2e2e">
                <Text color="#eee" size="12px">Feedback</Text>
            </Action>
            <Action type="button" background="#3ecf8e" radius="small" padding="6px,18px">
                <Text color="#171717" font="bold" size="12px">NEW PROJECT</Text>
            </Action>
        </Row>
    </Row>

    <Row spacing="24px" height="82vh" align="stretch">
        
        <!-- LEFT: Supabase Style Chat / Assistant -->
        <Column width="400px" background="#1c1c1c" radius="medium" border="1px solid #2e2e2e" padding="0" overflow="hidden">
            <!-- Header -->
            <Row background="#232323" padding="16px,24px" justify="between" align="center" border="0,0,1px,0,solid,#2e2e2e">
                <Text color="#eee" font="bold" size="14px">Supabase Assistant</Text>
                <Container background="#3ecf8e/10" padding="2px,8px" radius="full">
                    <Text color="#3ecf8e" size="10px" font="bold">AI</Text>
                </Container>
            </Row>

            <!-- Chat Session -->
            <Column expand="true" padding="24px" spacing="24px" overflow="auto">
                <Row spacing="12px" align="start">
                    <Container background="#232323" radius="medium" padding="16px" border="1px solid #2e2e2e" max-width="90%">
                        <Text color="#aaa" size="13px">Ho aggiornato la palette colori seguendo lo stile di **Supabase**. Ora l'ambiente è più sobrio e professionale. Cosa ne pensi? 🍃</Text>
                    </Container>
                </Row>

                <Row spacing="12px" align="start" justify="end">
                    <Container background="#3ecf8e/10" radius="medium" padding="16px" border="1px solid #3ecf8e44" max-width="90%">
                        <Text color="#eee" size="13px">Molto meglio, ora sembra un vero tool BaaS. Aggiorna i tag della Kanban.</Text>
                    </Container>
                </Row>

                <Row spacing="12px" align="start">
                    <Container background="#232323" radius="medium" padding="16px" border="1px solid #2e2e2e" max-width="90%">
                        <Text color="#aaa" size="13px">Certamente! Ho rimosso i gradienti eccessivi per un look più "clean" da dashboard gestionale. Procedo con la Kanban. ✅</Text>
                    </Container>
                </Row>
            </Column>

            <!-- Chat Command Input -->
            <Column padding="24px" background="#1c1c1c" border="1px,0,0,0,solid,#2e2e2e">
                <Container background="#232323" radius="medium" border="1px solid #2e2e2e" padding="4px,12px">
                    <Row align="center" spacing="12px">
                        <Icon name="bi-plus-lg" color="#666" size="14px" />
                        <Text type="p" color="#666" size="13px">Scrivi un comando...</Text>
                        <Row expand="true" justify="end">
                            <Container background="#3ecf8e" radius="small" width="24px" height="24px" align="center" justify="center">
                                <Icon name="bi-arrow-up-short" color="#171717" size="18px" />
                            </Container>
                        </Row>
                    </Row>
                </Container>
            </Column>
        </Column>

        <!-- CENTER: Data/Job Management Canvas -->
        <Column expand="true" spacing="24px">
            <Row justify="between" align="center" padding="0,10px">
                <Column>
                    <Text type="h2" color="#FFF" font="bold" size="24px">Table Management</Text>
                    <Text color="#666" size="12px">Viewing all current jobs in <Text color="#eee">public.tasks</Text></Text>
                </Column>
                <Row spacing="16px">
                    <Container background="#2e2e2e" padding="6px,14px" radius="small">
                         <Row align="center" spacing="8px">
                             <Icon name="bi-funnel" color="#aaa" size="14px" />
                             <Text color="#aaa" size="12px">Filter</Text>
                         </Row>
                    </Container>
                    <Container background="#3ecf8e" padding="6px,14px" radius="small">
                         <Text color="#171717" font="bold" size="12px">Insert Row</Text>
                    </Container>
                </Row>
            </Row>

            <!-- Kanban/Table Grid -->
            <Row spacing="20px" align="stretch" expand="true">
                <!-- TODO -->
                <Column width="1/3" background="#1c1c1c" radius="medium" border="1px solid #2e2e2e" padding="0" overflow="hidden">
                    <Row background="#232323" padding="10px,16px" justify="between" align="center" border="0,0,1px,0,solid,#2e2e2e">
                        <Text font="bold" color="#666" size="12px">TODO</Text>
                        <Text color="#666" size="10px">2 ITEMS</Text>
                    </Row>
                    <Column padding="16px" spacing="12px">
                        <Container background="#171717" radius="small" padding="16px" border="1px solid #2e2e2e">
                             <Text color="#eee" font="bold" size="13px" margin="0,0,4px,0">Database Schema Fix</Text>
                             <Text color="#666" size="11px">Review migrations for auth.</Text>
                        </Container>
                        <Container background="#171717" radius="small" padding="16px" border="1px solid #2e2e2e">
                             <Text color="#eee" font="bold" size="13px" margin="0,0,4px,0">Webhooks Init</Text>
                             <Text color="#666" size="11px">Setup Stripe listeners.</Text>
                        </Container>
                    </Column>
                </Column>

                <!-- DEVELOPING -->
                <Column width="1/3" background="#1c1c1c" radius="medium" border="1px solid #2e2e2e" padding="0" overflow="hidden">
                    <Row background="#232323" padding="10px,16px" justify="between" align="center" border="0,0,1px,0,solid,#2e2e2e">
                        <Text font="bold" color="#3ecf8e" size="12px">DEVELOPING</Text>
                        <Container background="#3ecf8e/15" radius="full" padding="1px,6px">
                            <Text color="#3ecf8e" size="10px">1</Text>
                        </Container>
                    </Row>
                    <Column padding="16px">
                        <Container background="#171717" radius="small" padding="16px" border="1px solid #3ecf8e">
                             <Row justify="between" margin="0,0,10px,0">
                                 <Text color="#3ecf8e" size="10px" font="bold">ACTIVE</Text>
                                 <Icon name="bi-activity" color="#3ecf8e" size="12px" />
                             </Row>
                             <Text color="#eee" font="bold" size="13px" margin="0,0,4px,0">Edge Functions UI</Text>
                             <Text color="#666" size="11px">Integrating with Supabase palette.</Text>
                        </Container>
                    </Column>
                </Column>

                <!-- COMPLETED -->
                <Column width="1/3" background="#1c1c1c" radius="medium" border="1px solid #2e2e2e" padding="0" overflow="hidden">
                    <Row background="#232323" padding="10px,16px" justify="between" align="center" border="0,0,1px,0,solid,#2e2e2e">
                        <Text font="bold" color="#666" size="12px">COMPLETED</Text>
                    </Row>
                    <Column padding="16px">
                        <Container background="#171717" radius="small" padding="16px" border="1px solid #2e2e2e" opacity="0.4">
                             <Text color="#666" font="bold" size="13px" style="text-decoration: line-through;">BaaS Vibe Setup</Text>
                             <Icon name="bi-check2-all" color="#3ecf8e" margin="10px,0,0,0" />
                        </Container>
                    </Column>
                </Column>
            </Row>
        </Column>
    </Row>
</Window>
