<?xml version="1.0" encoding="UTF-8"?>
<Window type="page" title="Cartoleria Irpina | La Tua Carta ad Avellino" background="#fdfbf7,#f5f2eb" font="sans">
    
    <!-- Navbar -->
    <Navigation width="full" background="#1a365d" padding="15px,40px" shadow="medium">
        <Row justify="between" align="center">
            <Row align="center" spacing="12px">
                <Icon name="bi-file-earmark-text-fill" size="28px" color="#ffd700" />
                <Column>
                    <Text type="h4" font="extrabold" color="#ffffff" spacing="1px">CARTOLERIA IRPINA</Text>
                    <Text size="12px" color="#ffd700" uppercase="true" font="bold">Avellino &amp; Provincia</Text>
                </Column>
            </Row>
            
            <Row spacing="25px" align="center">
                <Action type="link" route="/cartoleria"><Text color="#ffffff" font="bold">Home</Text></Action>
                <Action type="link" route="#prodotti"><Text color="#cbd5e0">Prodotti</Text></Action>
                <Action type="link" route="#servizi"><Text color="#cbd5e0">Servizi</Text></Action>
                <Action type="button" background="#ffd700" radius="medium" padding="8px,20px">
                    <Text color="#1a365d" font="bold">ORDINA ORA</Text>
                </Action>
            </Row>
        </Row>
    </Navigation>

    <!-- Hero Section -->
    <Column width="full" padding="80px,20px" align="center" background="#1a365d,#2a4365" spacing="30px">
        <Column align="center" spacing="15px" max-width="900px">
            <Container background="#ffd70020" padding="6px,18px" radius="full" border="1px solid #ffd70040">
                <Text size="14px" color="#ffd700" font="bold" uppercase="true">Specialisti in Carta di Qualità</Text>
            </Container>
            <Text type="h1" font="extrabold" size="52px" color="#ffffff" align="center">
                La migliore carta per il tuo ufficio, <Text color="#ffd700">direttamente a casa tua.</Text>
            </Text>
            <Text type="p" size="20px" color="#e2e8f0" align="center">
                Consegna rapida in tutta la provincia di Avellino. 
                Scegli la qualità, paga comodamente alla consegna.
            </Text>
        </Column>
        
        <Row spacing="20px">
            <Action type="button" background="#ffd700" padding="15px,35px" radius="medium" shadow="large">
                <Text font="bold" color="#1a365d" size="18px">Sfoglia Catalogo</Text>
            </Action>
            <Action type="button" border="2px solid #ffffff30" background="transparent" padding="15px,35px" radius="medium">
                <Text font="bold" color="#ffffff" size="18px">Contattaci su WhatsApp</Text>
            </Action>
        </Row>
    </Column>

    <!-- Features Section -->
    <Row width="full" padding="40px,10%" justify="around" background="#ffffff" border-bottom="1px solid #e2e8f0">
        <Column align="center" spacing="10px">
            <Icon name="bi-truck" size="40px" color="#1a365d" />
            <Text font="bold" size="18px" color="#2d3748">Spedizione Gratuita</Text>
            <Text size="14px" color="#718096">In tutta la provincia di AV</Text>
        </Column>
        <Divider type="vertical" height="60px" color="#e2e8f0" />
        <Column align="center" spacing="10px">
            <Icon name="bi-cash-coin" size="40px" color="#1a365d" />
            <Text font="bold" size="18px" color="#2d3748">Pagamento a Domicilio</Text>
            <Text size="14px" color="#718096">Paga alla consegna (Contrassegno)</Text>
        </Column>
        <Divider type="vertical" height="60px" color="#e2e8f0" />
        <Column align="center" spacing="10px">
            <Icon name="bi-geo-alt-fill" size="40px" color="#1a365d" />
            <Text font="bold" size="18px" color="#2d3748">Specialisti Locali</Text>
            <Text size="14px" color="#718096">Conosciamo bene il territorio</Text>
        </Column>
    </Row>

    <!-- Categories / Products -->
    <Column id="prodotti" width="full" padding="80px,5%" spacing="50px">
        <Column align="center" spacing="10px">
            <Text type="h2" font="extrabold" color="#1a365d">Il Nostro Assortimento</Text>
            <Text color="#718096">Materiali selezionati per ogni esigenza professionale e creativa</Text>
        </Column>

        <Grid class="grid-cols-1 md:grid-cols-2 lg:grid-cols-4" spacing="25px">
            <!-- Product 1 -->
            <Column background="#ffffff" padding="30px" radius="large" shadow="medium" border="1px solid #edf2f7" spacing="20px">
                <Container background="#ebf8ff" height="180px" radius="medium" align="center" justify="center">
                    <Icon name="bi-layers" size="64px" color="#3182ce" />
                </Container>
                <Column spacing="5px">
                    <Text font="bold" size="18px">Carta A4 Standard</Text>
                    <Text size="14px" color="#718096">80g - Ideale per fotocopie e stampa quotidiana.</Text>
                </Column>
                <Row justify="between" align="center">
                    <Text font="extrabold" size="20px" color="#2d3748">€ 4,50 <Text size="12px" color="#a0aec0" font="normal">/ risma</Text></Text>
                    <Action type="button" background="#1a365d" radius="full" padding="8px">
                        <Icon name="bi-plus" color="#ffffff" size="20px" />
                    </Action>
                </Row>
            </Column>

            <!-- Product 2 -->
            <Column background="#ffffff" padding="30px" radius="large" shadow="medium" border="1px solid #edf2f7" spacing="20px">
                <Container background="#faf5ff" height="180px" radius="medium" align="center" justify="center">
                    <Icon name="bi-image" size="64px" color="#805ad5" />
                </Container>
                <Column spacing="5px">
                    <Text font="bold" size="18px">Carta Fotografica</Text>
                    <Text size="14px" color="#718096">Premium Glossy - Per stampe ad alta definizione.</Text>
                </Column>
                <Row justify="between" align="center">
                    <Text font="extrabold" size="20px" color="#2d3748">€ 12,90</Text>
                    <Action type="button" background="#1a365d" radius="full" padding="8px">
                        <Icon name="bi-plus" color="#ffffff" size="20px" />
                    </Action>
                </Row>
            </Column>

            <!-- Product 3 -->
            <Column background="#ffffff" padding="30px" radius="large" shadow="medium" border="1px solid #edf2f7" spacing="20px">
                <Container background="#fffaf0" height="180px" radius="medium" align="center" justify="center">
                    <Icon name="bi-pencil-palette" size="64px" color="#dd6b20" />
                </Container>
                <Column spacing="5px">
                    <Text font="bold" size="18px">Carta Artistica</Text>
                    <Text size="14px" color="#718096">Grana ruvida - Ideale per acquerello e disegno.</Text>
                </Column>
                <Row justify="between" align="center">
                    <Text font="extrabold" size="20px" color="#2d3748">€ 15,00</Text>
                    <Action type="button" background="#1a365d" radius="full" padding="8px">
                        <Icon name="bi-plus" color="#ffffff" size="20px" />
                    </Action>
                </Row>
            </Column>

            <!-- Product 4 -->
            <Column background="#ffffff" padding="30px" radius="large" shadow="medium" border="1px solid #edf2f7" spacing="20px">
                <Container background="#f0fff4" height="180px" radius="medium" align="center" justify="center">
                    <Icon name="bi-briefcase" size="64px" color="#38a169" />
                </Container>
                <Column spacing="5px">
                    <Text font="bold" size="18px">Kit Officina</Text>
                    <Text size="14px" color="#718096">Carta chimica per ricevute e moduli continui.</Text>
                </Column>
                <Row justify="between" align="center">
                    <Text font="extrabold" size="20px" color="#2d3748">€ 8,50</Text>
                    <Action type="button" background="#1a365d" radius="full" padding="8px">
                        <Icon name="bi-plus" color="#ffffff" size="20px" />
                    </Action>
                </Row>
            </Column>
        </Grid>
    </Column>

    <!-- Info Section / Trust -->
    <Column width="full" background="#f7fafc" padding="80px,10%" spacing="40px">
        <Row align="center" spacing="40px">
            <Column expand="true" spacing="20px">
                <Text type="h2" font="extrabold" color="#1a365d">Perché scegliere noi?</Text>
                <Column spacing="15px">
                    <Row align="center" spacing="15px">
                        <Icon name="bi-check-circle-fill" color="#38a169" />
                        <Text color="#4a5568">Siamo presenti sul territorio di Avellino da oltre 20 anni.</Text>
                    </Row>
                    <Row align="center" spacing="15px">
                        <Icon name="bi-check-circle-fill" color="#38a169" />
                        <Text color="#4a5568">Consegna garantita entro 24/48 ore dall'ordine.</Text>
                    </Row>
                    <Row align="center" spacing="15px">
                        <Icon name="bi-check-circle-fill" color="#38a169" />
                        <Text color="#4a5568">Pagamento flessibile: Bonifico, Carta o Contanti alla consegna.</Text>
                    </Row>
                    <Row align="center" spacing="15px">
                        <Icon name="bi-check-circle-fill" color="#38a169" />
                        <Text color="#4a5568">Assistenza personalizzata per aziende e professionisti.</Text>
                    </Row>
                </Column>
            </Column>
            <Column width="400px" background="#ffffff" padding="40px" shadow="max" radius="xlarge" border="1px solid #e2e8f0">
                <Text type="h4" font="bold" color="#1a365d" margin="0,0,20px,0">Inviaci un messaggio</Text>
                <Column spacing="15px">
                    <Input type="text" placeholder="Nome completo" padding="12px" radius="medium" border="1px solid #cbd5e0" />
                    <Input type="email" placeholder="Email o Telefono" padding="12px" radius="medium" border="1px solid #cbd5e0" />
                    <Input type="textarea" placeholder="Di cosa hai bisogno?" padding="12px" radius="medium" border="1px solid #cbd5e0" height="100px" />
                    <Action type="submit" background="#1a365d" padding="15px" radius="medium">
                        <Text font="bold" color="#ffffff">Invia Richiesta</Text>
                    </Action>
                </Column>
            </Column>
        </Row>
    </Column>

    <!-- Footer -->
    <Column width="full" background="#1a365d" padding="60px,5%,20px,5%" spacing="40px">
        <Grid class="grid-cols-1 md:grid-cols-4" spacing="40px">
            <Column spacing="15px">
                <Row align="center" spacing="10px">
                    <Icon name="bi-file-earmark-text-fill" size="24px" color="#ffd700" />
                    <Text type="h5" font="bold" color="#ffffff">CARTOLERIA IRPINA</Text>
                </Row>
                <Text color="#a0aec0" size="14px">
                    Il partner affidabile per la fornitura di carta e cancelleria nella provincia di Avellino.
                </Text>
            </Column>
            <Column spacing="15px">
                <Text font="bold" color="#ffffff">Link Rapidi</Text>
                <Text color="#a0aec0" size="14px">Chi Siamo</Text>
                <Text color="#a0aec0" size="14px">Catalogo Prodotti</Text>
                <Text color="#a0aec0" size="14px">Spedizioni e Consegna</Text>
                <Text color="#a0aec0" size="14px">Privacy Policy</Text>
            </Column>
            <Column spacing="15px">
                <Text font="bold" color="#ffffff">Contatti</Text>
                <Row spacing="10px"><Icon name="bi-geo-alt" color="#ffd700" /><Text color="#a0aec0" size="14px">Avellino, Corso Vittorio Emanuele</Text></Row>
                <Row spacing="10px"><Icon name="bi-telephone" color="#ffd700" /><Text color="#a0aec0" size="14px">+39 0825 123456</Text></Row>
                <Row spacing="10px"><Icon name="bi-whatsapp" color="#ffd700" /><Text color="#a0aec0" size="14px">+39 333 4455667</Text></Row>
            </Column>
            <Column spacing="15px">
                <Text font="bold" color="#ffffff">Newsletter</Text>
                <Text color="#a0aec0" size="14px">Rimani aggiornato sulle nostre offerte mensili.</Text>
                <Row spacing="5px">
                    <Input type="email" placeholder="Email" padding="8px" radius="medium" background="#2d4365" color="#ffffff" border="none" expand="true" />
                    <Action type="button" background="#ffd700" padding="8px,15px" radius="medium"><Icon name="bi-send" color="#1a365d" /></Action>
                </Row>
            </Column>
        </Grid>
        <Divider color="#2d4365" thickness="1px" />
        <Row justify="between" align="center">
            <Text color="#718096" size="12px">© 2026 Cartoleria Irpina. Tutti i diritti riservati.</Text>
            <Row spacing="15px">
                <Icon name="bi-facebook" color="#a0aec0" />
                <Icon name="bi-instagram" color="#a0aec0" />
                <Icon name="bi-linkedin" color="#a0aec0" />
            </Row>
        </Row>
    </Column>

</Window>
