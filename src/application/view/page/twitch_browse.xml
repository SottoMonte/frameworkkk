{% extends "twitch_layout.xml" %}

{% block content %}
<Column width="full" padding="20px,32px" spacing="24px">
    <Text type="h1" font="bold" color="#ffffff" size="48px">Browse</Text>
    
    <!-- Browse Tabs -->
    <Row spacing="24px" margin="0,0,16px,0">
        <Column align="center" spacing="4px">
            <Text type="h4" font="bold" color="#9146ff" pointer="pointer" size="18px">Categories</Text>
            <Container height="2px" width="full" background="#9146ff" />
        </Column>
        <Column align="center" spacing="4px">
            <Text type="h4" font="bold" color="#ffffff" pointer="pointer" size="18px" hover-color="#9146ff">Live Channels</Text>
        </Column>
    </Row>

    <!-- Filter Bar -->
    <Row justify="between" align="center" width="full">
        <Row spacing="12px" align="center">
            <Text color="#adadb8" font="bold" size="14px">Filter by</Text>
            <Action type="button" background="#26262c" padding="6px,12px" radius="medium" hover-background="#35353b">
                <Row align="center" spacing="8px">
                    <Text color="#ffffff" font="bold" size="13px">Tags</Text>
                    <Icon name="bi-caret-down-fill" size="14px" color="#ffffff" />
                </Row>
            </Action>
        </Row>
        
        <Row spacing="12px" align="center">
            <Text color="#adadb8" font="bold" size="14px">Sort by</Text>
            <Action type="button" background="#26262c" padding="6px,12px" radius="medium" hover-background="#35353b">
                <Row align="center" spacing="8px">
                    <Text color="#ffffff" font="bold" size="13px">Recommended For You</Text>
                    <Icon name="bi-caret-down-fill" size="14px" color="#ffffff" />
                </Row>
            </Action>
        </Row>
    </Row>

    <!-- Categories Grid -->
    <Grid rows="2" columns="6" spacing="16px" width="full">
        <TwitchCategoryCard name="Just Chatting" thumb="JC" viewers="534K" />
        <TwitchCategoryCard name="League of Legends" thumb="LOL" viewers="128K" />
        <TwitchCategoryCard name="Valorant" thumb="VAL" viewers="210K" />
        <TwitchCategoryCard name="Grand Theft Auto V" thumb="GTA" viewers="345K" />
        <TwitchCategoryCard name="Minecraft" thumb="MC" viewers="112K" />
        <TwitchCategoryCard name="Fortnite" thumb="FN" viewers="89K" />
        <TwitchCategoryCard name="Dota 2" thumb="D2" viewers="145K" />
        <TwitchCategoryCard name="CS2" thumb="CS" viewers="192K" />
        <TwitchCategoryCard name="Elden Ring" thumb="ER" viewers="56K" />
        <TwitchCategoryCard name="Apex Legends" thumb="AL" viewers="72K" />
        <TwitchCategoryCard name="Rust" thumb="RU" viewers="45K" />
        <TwitchCategoryCard name="Hearthstone" thumb="HS" viewers="28K" />
    </Grid>
</Column>
{% endblock %}
