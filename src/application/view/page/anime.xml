<?xml version="1.0" encoding="UTF-8"?>
<Window type="page" title="Anime Voting | Vota i tuoi preferiti" background="#0B0E14,#1a1c2c" font="sans">
    
    <!-- Navigation Bar -->
    <Navigation orientation="horizontal" alignment-content="between" padding="20px,40px" position="fixed" top="0" width="full" style="z-index: 50;" matter="glass-min">
        <Row align="center" spacing="10px">
            <Icon name="bi-play-btn-fill" size="24px" color="#FF3E00" />
            <Text type="h4" font="bold" color="#FFFFFF">AnimeVote</Text>
        </Row>
        <Row align="center" spacing="30px">
            <Action type="link" route="/portfolio"><Text color="#BBBBBB" hover-color="#FFFFFF">Portfolio</Text></Action>
            <Action type="link" route="/anime"><Text color="#FFFFFF" font="bold">Vota</Text></Action>
            <Action type="link" route="#" background="#FF3E00,#FF8A00" padding="8px,20px" radius="full">
                <Text font="bold" color="#FFFFFF">Login</Text>
            </Action>
        </Row>
    </Navigation>

    <Column width="full" padding="100px,20px,40px,20px" align="center" spacing="60px">
        
        <!-- Hero Section -->
        <Column align="center" spacing="20px" padding="40px,0">
            <Text type="h1" font="extrabold" size="56px" color="#FFFFFF" align="center">Vota i migliori Anime</Text>
            <Text type="p" size="20px" color="#AAAAAA" width="700px" align="center">
                Esprimi il tuo parere sulle serie del momento. Il tuo voto conta!
            </Text>
        </Column>

        <!-- Anime Voting Grid -->
        <Grid class="grid-cols-1 md:grid-cols-2 lg:grid-cols-3" spacing="30px" width="full" max-width="1200px">
            
            <!-- Anime Card 1 -->
            <Column background="#161b22" radius="large" overflow="hidden" border="1px solid #ffffff10" hover-border="1px solid #FF3E00">
                <Media type="image" src="https://images.unsplash.com/photo-1578632738980-302302353198?auto=format&amp;fit=crop&amp;w=800&amp;q=80" width="full" height="300px" />
                <Column padding="25px" spacing="15px">
                    <Row justify="between" align="center">
                        <Text type="h4" font="bold" color="#FFFFFF">Cyberpunk: Edgerunners</Text>
                        <Container background="#FF3E0020" padding="2px,8px" radius="small">
                            <Text size="12px" color="#FF3E00" font="bold">ACTION</Text>
                        </Container>
                    </Row>
                    <Text color="#AAA" size="14px">Un mercenario cerca di sopravvivere in una città ossessionata dalla tecnologia e dai potenziamenti corporei.</Text>
                    
                    <Divider thickness="1px" color="#ffffff10" margin="10px,0" />
                    
                    <Column spacing="8px">
                        <Row justify="between">
                            <Text color="#888" size="13px">Il tuo voto:</Text>
                            <Text color="#FF3E00" font="bold" size="14px">1..10</Text>
                        </Row>
                        <Input type="range" min="1" max="10" value="8" width="full" />
                        <Action type="button" background="#FF3E00" width="full" padding="10px" radius="medium" margin="10px,0,0,0">
                            <Text font="bold" color="#FFFFFF">INVIA VOTO</Text>
                        </Action>
                    </Column>
                </Column>
            </Column>

            <!-- Anime Card 2 -->
            <Column background="#161b22" radius="large" overflow="hidden" border="1px solid #ffffff10" hover-border="1px solid #FF3E00">
                <Media type="image" src="https://images.unsplash.com/photo-1541562232579-512a21360020?auto=format&amp;fit=crop&amp;w=800&amp;q=80" width="full" height="300px" />
                <Column padding="25px" spacing="15px">
                    <Row justify="between" align="center">
                        <Text type="h4" font="bold" color="#FFFFFF">Frieren: Beyond Journey's End</Text>
                        <Container background="#00D2FF20" padding="2px,8px" radius="small">
                            <Text size="12px" color="#00D2FF" font="bold">FANTASY</Text>
                        </Container>
                    </Row>
                    <Text color="#AAA" size="14px">Dopo la sconfitta del Re Demone, l'elfa Frieren inizia un nuovo viaggio per comprendere l'umanità.</Text>
                    
                    <Divider thickness="1px" color="#ffffff10" margin="10px,0" />
                    
                    <Column spacing="8px">
                        <Row justify="between">
                            <Text color="#888" size="13px">Il tuo voto:</Text>
                            <Text color="#00D2FF" font="bold" size="14px">1..10</Text>
                        </Row>
                        <Input type="range" min="1" max="10" value="9" width="full" />
                        <Action type="button" background="#00D2FF" width="full" padding="10px" radius="medium" margin="10px,0,0,0">
                            <Text font="bold" color="#FFFFFF">INVIA VOTO</Text>
                        </Action>
                    </Column>
                </Column>
            </Column>

            <!-- Anime Card 3 -->
            <Column background="#161b22" radius="large" overflow="hidden" border="1px solid #ffffff10" hover-border="1px solid #FF3E00">
                <Media type="image" src="https://images.unsplash.com/photo-1560972550-aba3456b5564?auto=format&amp;fit=crop&amp;w=800&amp;q=80" width="full" height="300px" />
                <Column padding="25px" spacing="15px">
                    <Row justify="between" align="center">
                        <Text type="h4" font="bold" color="#FFFFFF">Neon Genesis Evangelion</Text>
                        <Container background="#9D50BB20" padding="2px,8px" radius="small">
                            <Text size="12px" color="#9D50BB" font="bold">MECHA</Text>
                        </Container>
                    </Row>
                    <Text color="#AAA" size="14px">Piloti adolescenti combattono esseri angelici giganti in un mondo sull'orlo della distruzione.</Text>
                    
                    <Divider thickness="1px" color="#ffffff10" margin="10px,0" />
                    
                    <Column spacing="8px">
                        <Row justify="between">
                            <Text color="#888" size="13px">Il tuo voto:</Text>
                            <Text color="#9D50BB" font="bold" size="14px">1..10</Text>
                        </Row>
                        <Input type="range" min="1" max="10" value="10" width="full" />
                        <Action type="button" background="#9D50BB" width="full" padding="10px" radius="medium" margin="10px,0,0,0">
                            <Text font="bold" color="#FFFFFF">INVIA VOTO</Text>
                        </Action>
                    </Column>
                </Column>
            </Column>

        </Grid>

        <!-- Footer -->
        <Divider width="full" thickness="1px" color="#ffffff10" />
        <Row width="full" justify="between" align="center" padding="0,0,40px,0">
            <Text color="#555">© 2026 AnimeVote. Made with OmniPort.</Text>
            <Row spacing="20px">
                <Action type="link" route="#"><Icon name="bi-instagram" color="#555" hover-color="#FFFFFF" /></Action>
                <Action type="link" route="#"><Icon name="bi-discord" color="#555" hover-color="#FFFFFF" /></Action>
            </Row>
        </Row>

    </Column>

</Window>
