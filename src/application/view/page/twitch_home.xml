{% extends "twitch_layout.xml" %}

{% block content %}
<Column width="full" padding="20px,32px" spacing="32px">
    <!-- Featured Hero Section -->
    <Container width="full" height="360px" background="#18181b" radius="large" overflow="hidden" position="relative" shadow="large">
        <Row height="full" align="center" spacing="20px" padding="32px">
            <Container width="60%" height="full" background="#0e0e10" radius="medium" overflow="hidden" border="1px solid #1f1f23">
                <!-- Video Player Placeholder -->
                <Column align="center" justify="center" height="full">
                    <Icon name="bi-play-fill" size="64px" color="#9146ff" />
                    <Text type="h5" font="bold" color="#ffffff">Featured Live Content</Text>
                </Column>
            </Container>
            <Column flex-grow="1" height="full" spacing="12px" padding="0,16px">
                <Row align="center" spacing="12px">
                    <Container width="48px" height="48px" background="#9146ff" radius="full" align="center" justify="center">
                        <Text font="bold" color="#ffffff">XQ</Text>
                    </Container>
                    <Column>
                        <Text type="h5" font="bold" color="#ffffff">xQc</Text>
                        <Text type="p" color="#9146ff" size="14px">Just Chatting</Text>
                    </Column>
                </Row>
                <Text type="p" color="#adadb8" size="15px" line-clamp="4">
                    THE JUICER IS LIVE! THE ARENA IS READY. COME JOIN THE CRAZINESS. REACTIONS, GAMES, AND MORE!
                </Text>
                
                <Row wrap="wrap" spacing="8px" margin="12px,0">
                    <Container background="#26262c" padding="2px,12px" radius="full">
                        <Text size="12px" color="#efeff1" font="bold">English</Text>
                    </Container>
                    <Container background="#26262c" padding="2px,12px" radius="full">
                        <Text size="12px" color="#efeff1" font="bold">Variety</Text>
                    </Container>
                    <Container background="#26262c" padding="2px,12px" radius="full">
                        <Text size="12px" color="#efeff1" font="bold">NoPixel</Text>
                    </Container>
                </Row>
                
                <Action type="button" background="#9146ff" radius="medium" padding="10px,20px" hover-background="#772ce8" align-self="start">
                    <Text font="bold" color="#ffffff">Watch Now</Text>
                </Action>
            </Column>
        </Row>
        
        <!-- Navigation Buttons -->
        <Container position="absolute" top="0" left="0" height="full" width="60px" padding="10px" align="center" justify="center">
            <Icon name="bi-chevron-left" size="32px" color="#ffffff" pointer="pointer" />
        </Container>
         <Container position="absolute" top="0" right="0" height="full" width="60px" padding="10px" align="center" justify="center">
            <Icon name="bi-chevron-right" size="32px" color="#ffffff" pointer="pointer" />
        </Container>
    </Container>

    <!-- Recommended Channels Grid -->
    <Column width="full" spacing="16px">
        <Text type="h4" font="bold" color="#ffffff">
            Live Channels We Think You'll Like
        </Text>
        <Grid rows="1" columns="3" spacing="16px" width="full">
            <TwitchStreamCard name="shroud" thumb="SH" title="ROAD TO RADIANT | VALORANT RANKED" category="Valorant" viewers="45,210" />
            <TwitchStreamCard name="Summit1g" thumb="S1" title="DAYZ SURVIVAL | HARDCORE SERVER" category="DayZ" viewers="22,104" />
            <TwitchStreamCard name="HasanAbi" thumb="HA" title="NEWS &amp; REACTION | JUICY DRAMA" category="Just Chatting" viewers="31,500" />
        </Grid>
    </Column>

    <!-- Popular Categories -->
    <Column width="full" spacing="16px">
         <Text type="h4" font="bold" color="#ffffff">
            Popular Categories
        </Text>
        <Grid rows="1" columns="6" spacing="16px" width="full">
            <TwitchCategoryCard name="Just Chatting" thumb="JC" viewers="250K" />
            <TwitchCategoryCard name="League of Legends" thumb="LOL" viewers="120K" />
            <TwitchCategoryCard name="Valorant" thumb="VAL" viewers="180K" />
            <TwitchCategoryCard name="Minecraft" thumb="MC" viewers="85K" />
            <TwitchCategoryCard name="Fortnite" thumb="FN" viewers="95K" />
            <TwitchCategoryCard name="Elden Ring" thumb="ER" viewers="45K" />
        </Grid>
    </Column>
</Column>
{% endblock %}
