<Window type="page" title="YouTube - Watch" background="#0f0f0f">
    <TopNav />
    <Row width="full" height="full" align="start" padding="24px,70px" spacing="24px">
        <Column width="70%" spacing="16px">
            <Container width="full" height="480px" background="#000" radius="12px" overflow="hidden">
                 <Icon name="bi-play-btn" size="64px" color="#333" align="center" justify="center" margin="200px,0" />
            </Container>

            <Column spacing="8px">
                <Text type="h1" color="white" font="bold" size="24px">Building a video platform in 2026</Text>
                <Row justify="between" align="center" width="full">
                    <Row align="center" spacing="12px">
                        <Container width="40px" height="40px" background="#568dff" radius="full" align="center" justify="center">
                            <Text font="bold" color="white">V</Text>
                        </Container>
                        <Column>
                            <Text font="bold" color="white" size="16px">VibeCoding</Text>
                            <Text color="#aaa" size="12px">1.2M subscribers</Text>
                        </Column>
                        <Action type="button" background="white" radius="full" padding="8px,16px" margin="0,0,0,12px">
                            <Text font="bold" color="black" size="14px">Subscribe</Text>
                        </Action>
                    </Row>
                    <Row spacing="8px">
                        <Row background="#272727" radius="full" align="center" overflow="hidden">
                            <Action type="button" padding="8px,16px" border-right="1px solid #3f3f3f">
                                <Row align="center" spacing="8px">
                                    <Icon name="bi-hand-thumbs-up" size="18px" color="white" />
                                    <Text font="bold" color="white" size="14px">120K</Text>
                                </Row>
                            </Action>
                            <Action type="button" padding="8px,16px">
                                <Icon name="bi-hand-thumbs-down" size="18px" color="white" />
                            </Action>
                        </Row>
                        <Action type="button" background="#272727" radius="full" padding="8px,16px">
                             <Row align="center" spacing="8px">
                                <Icon name="bi-share" size="18px" color="white" />
                                <Text font="bold" color="white" size="14px">Share</Text>
                            </Row>
                        </Action>
                        <Action type="button" background="#272727" radius="full" padding="8px,16px">
                            <Icon name="bi-three-dots" size="18px" color="white" />
                        </Action>
                    </Row>
                </Row>
            </Column>

            <Container width="full" background="#272727" radius="12px" padding="12px">
                <Row spacing="8px">
                    <Text font="bold" color="white" size="14px">1.2M views</Text>
                    <Text font="bold" color="white" size="14px">2 days ago</Text>
                </Row>
                <Text color="white" size="14px" margin="8px,0,0,0">
                    This video shows how to build a modern video platform using the latest OmniPort framework.
                    Subscribe for more coding vibes!
                </Text>
            </Container>

            <!-- Comments Section -->
            <Column spacing="20px" margin="24px,0,0,0">
                <Text type="h5" color="white" font="bold" size="20px">Comments</Text>
                <Row align="center" spacing="12px">
                    <Container width="40px" height="40px" background="#2ff801" radius="full" align="center" justify="center">
                         <Text font="bold" color="white">U</Text>
                    </Container>
                    <Input type="text" placeholder="Add a comment..." background="transparent" color="white" border-bottom="1px solid #3f3f3f" width="full" padding="8px,0" />
                </Row>

                <Row spacing="12px">
                    <Container width="40px" height="40px" background="#ff568d" radius="full" align="center" justify="center">
                        <Text font="bold" color="white">D</Text>
                    </Container>
                    <Column flex-grow="1">
                        <Row spacing="8px" align="center">
                             <Text font="bold" color="white" size="13px">@DevMaster</Text>
                             <Text color="#aaa" size="12px">3 hours ago</Text>
                        </Row>
                        <Text color="white" size="14px" margin="4px,0">Awesome quality content! Loved the architecture part.</Text>
                        <Row spacing="16px" align="center" margin="8px,0">
                             <Icon name="bi-hand-thumbs-up" size="14px" color="white" />
                             <Icon name="bi-hand-thumbs-down" size="14px" color="white" />
                             <Text font="bold" color="white" size="12px">Reply</Text>
                        </Row>
                    </Column>
                </Row>
            </Column>
        </Column>

        <!-- Sidebar Recommendations -->
        <Column width="30%" spacing="12px">
             <VideoCard id="3" title="Unboxing the latest Gemini 2.0" channel="TechReviews" views="2.1M" time="5 hours ago" duration="10:05" />
             <VideoCard id="4" title="10 tips for Better UI Design" channel="DesignMaster" views="89K" time="3 days ago" duration="8:30" />
             <VideoCard id="6" title="Why Rust is taking over" channel="FerrisDev" views="560K" time="2 weeks ago" duration="18:15" />
             <VideoCard id="7" title="The future of LLMs in 2026" channel="AIInsights" views="2M" time="1 day ago" duration="32:40" />
        </Column>
    </Row>
</Window>
