{% extends "mono.xml" %}
{% block content %}
<Column>
{% if session.errors %}
    {% for error in session.errors %}
        <Text>{{ error.field }}: {{ error.message }}</Text>
        <Text>{{ error }}</Text>
    {% endfor %}
{% endif %}
</Column>
<Container width="400" padding="48">
    <Action type="form" route="/signup" act="POST">
        <Input name="email" placeholder="email" />
        <Input name="password" placeholder="password" type="password" />
        <!--<Input name="password-repeat" placeholder="password repetition" type="password" />-->
        <Input name="username" placeholder="username" />
        <Action class="primary" type="submit" ><Text>Registrazione</Text></Action>
    </Action>
    <Action type="submit" route="/auth/signin">Already have an account? Sign in</Action>
</Container>
{% endblock %}