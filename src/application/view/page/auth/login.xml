                    <text x="20" y="510" fill="#ce9178">[presentation.backend]</text>
                    <text x="20" y="530"><tspan fill="#9cdcfe">adapter</tspan> = <tspan fill="#ce9178">"starlette"</tspan></text>
                    <text x="20" y="550"><tspan fill="#9cdcfe">host</tspan> = <tspan fill="#ce9178">"0.0.0.0"</tspan></text>
                    <text x="20" y="570"><tspan fill="#9cdcfe">port</tspan> = <tspan fill="#ce9178">"5000"</tspan></text>
                    
                    <text x="20" y="590" fill="#6a9955">#route = "web.xml"</text>
                    <text x="20" y="610" fill="#6a9955">#ssl_keyfile = "key.pem"</text>
                    <text x="20" y="630" fill="#6a9955">#ssl_certfile = "cert.pem"</text>
                </g>
            </svg>
        </Container>
        <Container width="1/3">
            <svg viewBox="0 0 800 560" xmlns="http://www.w3.org/2000/svg" class="omniport-gui-mockup" style="width: 100%; height: auto; display: block;">
                <defs>
                    <style type="text/css">
                        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&amp;display=swap');
                        
                        .window-frame { fill: #1e293b; }
                        .title-bar { fill: #0f172a; }
                        .title-text { fill: #94a3b8; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; letter-spacing: 0.02em; }
                        
