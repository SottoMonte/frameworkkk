                    <text x="20" y="350" fill="#ce9178">[message.backend]</text>
                    <text x="20" y="370"><tspan fill="#9cdcfe">adapter</tspan> = <tspan fill="#ce9178">"redis"</tspan></text>
                    <text x="20" y="390"><tspan fill="#9cdcfe">host</tspan> = <tspan fill="#ce9178">"your-cluster.redis..."</tspan></text>
                    <text x="20" y="410"><tspan fill="#9cdcfe">port</tspan> = <tspan fill="#ce9178">"13976"</tspan></text>
                    <text x="20" y="430"><tspan fill="#9cdcfe">database</tspan> = <tspan fill="#ce9178">"production-db"</tspan></text>
                    <text x="20" y="450"><tspan fill="#9cdcfe">username</tspan> = <tspan fill="#ce9178">"default"</tspan></text>
