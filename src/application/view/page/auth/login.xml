                <rect width="100%" height="35" rx="12" fill="#333333" />
                <circle cx="20" cy="17" r="5" fill="#ff5f56" />
                <circle cx="40" cy="17" r="5" fill="#ffbd2e" />
                <circle cx="60" cy="17" r="5" fill="#27c93f" />
                <text x="300" y="22" font-family="monospace" font-size="14" fill="#cccccc" text-anchor="middle">project.toml</text>

                <g font-family="monospace" font-size="13" fill="#d4d4d4">
                    <text x="20" y="70" fill="#ce9178">[project]</text>
                    <text x="20" y="90"><tspan fill="#9cdcfe">name</tspan> = <tspan fill="#ce9178">"cloud.colosso"</tspan> <tspan fill="#6a9955"># Nome del progetto</tspan></text>
                    <text x="20" y="110"><tspan fill="#9cdcfe">version</tspan> = <tspan fill="#ce9178">"0.1.0"</tspan> <tspan fill="#6a9955"># Versione dell'app</tspan></text>
                    <text x="20" y="130"><tspan fill="#9cdcfe">description</tspan> = <tspan fill="#ce9178">"A minimal sample app..."</tspan></text>
                    <text x="20" y="150"><tspan fill="#9cdcfe">readme</tspan> = <tspan fill="#ce9178">"README.md"</tspan></text>
