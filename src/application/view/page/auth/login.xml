                <line x1="0" y1="0" x2="0" y2="-500" class="section-line" transform="rotate(180)"/>
                <line x1="0" y1="0" x2="0" y2="-500" class="section-line" transform="rotate(270)"/>
            </g>

            <circle cx="500" cy="500" r="460" fill="none" stroke="#1e293b" stroke-width="1"/>
            <circle cx="500" cy="500" r="340" fill="none" stroke="#334155" stroke-width="2"/>
            <circle cx="500" cy="500" r="180" fill="none" stroke="#38BDF8" stroke-width="3"/>

            <g transform="translate(500, 500)">
                <path d="M 0 -420 A 420 420 0 0 1 420 0" class="infra-arc" stroke="#38BDF8"/>
                <path d="M 420 0 A 420 420 0 0 1 0 420" class="infra-arc" stroke="#fbbf24"/>
                <path d="M 0 420 A 420 420 0 0 1 -420 0" class="infra-arc" stroke="#64ffda"/>
                <path d="M -420 0 A 420 420 0 0 1 0 -420" class="infra-arc" stroke="#94a3b8"/>
            </g>

            <g transform="translate(500, 500)">
                <g transform="rotate(25) translate(0, -420) rotate(-25)">
                    <text text-anchor="middle" class="label-infra" y="-15">Presentation</text>
                    <text text-anchor="middle" class="tech-name">STARLETTE</text>
                </g>
                <g transform="rotate(65) translate(0, -420) rotate(-65)">
                    <text text-anchor="middle" class="label-infra" y="-15">Presentation</text>
                    <text text-anchor="middle" class="tech-name">WASM</text>
                </g>

                <g transform="rotate(135) translate(0, -420) rotate(-135)">
                    <text text-anchor="middle" class="label-infra" y="-15">Persistence</text>
                    <text text-anchor="middle" class="tech-name">SUPABASE</text>
                </g>

                <g transform="rotate(225) translate(0, -420) rotate(-225)">
                    <text text-anchor="middle" class="label-infra" y="-15">Message</text>
                    <text text-anchor="middle" class="tech-name">REDIS</text>
                </g>

                <g transform="rotate(315) translate(0, -420) rotate(-315)">
                    <text text-anchor="middle" class="label-infra" y="-15">Sensors</text>
                    <text text-anchor="middle" class="tech-name">MQTT / GPIO</text>
                </g>
            </g>

            <g transform="translate(500, 500)">
                <circle r="25" cx="0" cy="-340" class="app-role-circle"/>
                <text y="-337" text-anchor="middle" font-size="8">USE CASES</text>
                
                <circle r="25" cx="340" cy="0" class="app-role-circle"/>
                <text x="340" y="3" text-anchor="middle" font-size="8">AUTH</text>
            </g>

            <g transform="translate(500, 500)">
                <g transform="rotate(0) translate(0, -180)"><circle r="35" class="core-role-circle"/><text y="5" text-anchor="middle" font-size="9">DEFENDER</text></g>
                <g transform="rotate(72) translate(0, -180) rotate(-72)"><circle r="35" class="core-role-circle"/><text y="5" text-anchor="middle" font-size="9">MESSAGER</text></g>
                <g transform="rotate(144) translate(0, -180) rotate(-144)"><circle r="35" class="core-role-circle"/><text y="5" text-anchor="middle" font-size="9">EXECUTOR</text></g>
                <g transform="rotate(216) translate(0, -180) rotate(-216)"><circle r="35" class="core-role-circle"/><text y="5" text-anchor="middle" font-size="8">STOREKEEPER</text></g>
                <g transform="rotate(288) translate(0, -180) rotate(-288)"><circle r="35" class="core-role-circle"/><text y="5" text-anchor="middle" font-size="9">PRESENTER</text></g>
            </g>

            <text x="500" y="495" text-anchor="middle" font-size="20" font-weight="bold">CORE</text>
            <text x="500" y="520" text-anchor="middle" font-size="18" fill="#38BDF8">DOMAIN</text>
        </svg>
    </Container>
</Row>
<Container>
    <Column>
        <Container>
            <Text type="h1" >MVA > MVC</Text>
            <Text>[MODEL_VIEW_ACTION]</Text>
            <Divider/>
            <Text type="h1" >AI-OPTIMIZED ATOMICS</Text>
            <Text>Actions are single-purpose functions. AI models (LLMs) excel at writing specific actions with 100% test coverage, unlike monolithic controllers.</Text>
            <Text type="h1">VIBECODING READY</Text>
            <Text>Iterate on the "Vibe" of your UI while the Core remains immutable. Your logic is a set of deterministic assets, not technical debt.</Text>
        </Container>
        <Container>
            <Text type="h5" ># src/application/actions/create_user.py</Text>
            <Text type="code">class CreateUserAction:
                def execute(self, data: UserSchema) -> User:
                    user = User.initialize(data)
                    # Persistence Port call
                    self.repo.save(user)
                    return user
            </Text>
        </Container>
    </Column>
</Container>

