                    .tech-name { font-size: 14px; font-weight: bold; fill: #ffffff; }
                    .core-role-circle { fill: none; stroke: #64ffda; stroke-width: 2; }
                    .app-role-circle { fill: none; stroke: #fbbf24; stroke-width: 1.5; }
                </style>
            </defs>

            <rect width="1000" height="1000" fill="none"/>

            <g transform="translate(500, 500)">
                <line x1="0" y1="0" x2="0" y2="-500" class="section-line" transform="rotate(0)"/>
