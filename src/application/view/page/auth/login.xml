                    <rect x="20" y="20" width="760" height="510" rx="12" class="window-frame" stroke="#334155" stroke-width="1"/>
                    
                    <path d="M20 32C20 25.3726 25.3726 20 32 20H768C774.627 20 780 25.3726 780 32V60H20V32Z" class="title-bar"/>
                    
                    <path d="M20 60H780V518C780 524.627 774.627 530 768 530H32C25.3726 530 20 524.627 20 518V60Z" fill="#0b1120" />

                    <text x="400" y="46" text-anchor="middle" class="title-text">OmniPort IDE v0.1.0 — colosso.toml</text>
                    
                    <circle cx="45" cy="40" r="6" class="btn-close"/>
                    <circle cx="65" cy="40" r="6" class="btn-min"/>
                    <circle cx="85" cy="40" r="6" class="btn-max"/>

                    <rect x="21" y="21" width="758" height="508" rx="11" class="border-highlight" pointer-events="none"/>
                </g>
