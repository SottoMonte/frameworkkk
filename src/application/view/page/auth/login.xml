        </svg>
        <Text type="h5" font="bold" spacing="min" uppercase="true">Omni:domain</Text>
    </Row>
    <Action type='button' background='#568dff' ><Text font='bold'>TRY_NOW</Text></Action>
    <Divider thickness='1px' max-width='99%' background='#000000ff' position='absolute' left='0.5%' right='0.5%' bottom='0px' />
</Navigation>
<Column padding="50px">
    <Column justify='center' align='center' padding="3%,20%">
        <Text type='h1' font='black' spacing='min' align='center' margin='0,20px,0,0' size='90px'><Text type='span' background='#222222' >OMNIDOMAIN: THE </Text><Text type='span' background='#2ff801,#568dff' >OPERATING SYSTEM</Text><Text type='span' background='#222222' > FOR YOUR LOGIC</Text></Text>
        <Text type='h4' font='mono' align='center' uppercase='true'>Define the intent, choose the Port. The first Hexagonal framework built for the era of AI-driven development. </Text>
    </Column>
    <Row justify='center' align='center'>
        <Container width="1/3">
            <svg viewBox="0 0 800 560" xmlns="http://www.w3.org/2000/svg" class="omniport-gui-mockup" style="width: 100%; height: auto; display: block;">
                <defs>
                    <style type="text/css">
                        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600&amp;display=swap');
                        
