{% block main %}
<Navigation type='app' padding='0,0.5%' width="full" height="50px" justify='between' align='center' position='fixed' top='0px' background='#0B0E14/80'  matter='glass'>
    <Row height="100%" justify='center' align='center' spacing='10px'>
        <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 500" height="100%">
            <circle cx="250" cy="250" r="80" stroke="#568dff" stroke-width="25" fill="none" />
            
            <g stroke="#000000ff" stroke-width="8" stroke-linecap="round">
                <line x1="250" y1="50" x2="250" y2="130" />
                <path d="M235 115 L250 130 L265 115" fill="none" />
                
                <line x1="250" y1="450" x2="250" y2="370" />
                <path d="M235 385 L250 370 L265 385" fill="none" />
                
                <line x1="450" y1="250" x2="370" y2="250" />
                <path d="M385 235 L370 250 L385 265" fill="none" />
                
