<Column width="full" spacing="8px" pointer="pointer" transition="transform 0.2s" hover-transform="translateY(-4px)">
    <Action type="link" src="/twitch/browse/{{ component.attributes.name | lower }}">
        <Container width="full" height="240px" background="#9146ff" radius="large" overflow="hidden" position="relative" border="1px solid #1f1f23">
            <!-- Simulated Category Image (Gradient) -->
            <Container width="full" height="full" background="#1a1a1a,#4a1a4a" align="center" justify="center">
                <Text size="24px" font="bold" color="#ffffff" uppercase="true" align="center">{{ component.attributes.thumb }}</Text>
            </Container>
            
            <!-- Live Tag (Bottom Right) -->
            <Container position="absolute" bottom="10px" right="10px" background="#00000088" padding="2px,8px" radius="small" matter="glass-min">
                 <Text color="white" size="12px" font="bold">{{ component.attributes.viewers }} live</Text>
            </Container>
        </Container>
    </Action>
    
    <Column spacing="2px">
        <Text type="h6" color="#ffffff" font="bold" size="16px" truncate="true" hover-color="#9146ff">
            {{ component.attributes.name }}
        </Text>
        <Text color="#adadb8" size="13px">{{ component.attributes.viewers }} Viewers</Text>
    </Column>
</Column>
