{
  "service": {
    "type": "string",
    "required": false,
    "allowed": ["persistence", "messaging", "authentication", "authorization", "presentation", "network", "logging", "monitoring", "integration", "cache"]
  },
  "interface": {
    "type": "string",
    "required": false
  },
  "platform": {
    "type": "string",
    "required": false,
    "allowed": ["server", "browser", "mobile", "embedded"]
  },
  "provider": {
    "type": "string",
    "required": false,
    "regex": "^[a-zA-Z0-9_-]+$"
  },
  "capabilities": {
    "type": "dict",
    "required": false,
    "schema": {
      "type": "string"
    }
  },
  "constraints": {
    "type": "dict",
    "required": false
  },
  "sla": {
    "type": "dict",
    "required": false,
    "schema": "{{ user }}"
  },
  "priority": {
    "type": "string",
    "required": false,
    "allowed": ["low", "normal", "high", "critical"]
  },
  "cost_sensitivity": {
    "type": "string",
    "required": false,
    "allowed": ["low", "medium", "high"]
  }
}
