{
  "provider": {
    "type": "string",
    "required": true,
    "default": "unknown",
    "empty": false,
    "regex": "^[a-zA-Z0-9_-]+$"
  },
  "location": {
    "type": "string",
    "required": false,
    "default": "",
    "nullable": true
  },
  "operation": {
    "type": "string",
    "required": true,
    "default": "read",
    "allowed": [
      "create",
      "read",
      "update",
      "delete",
      "view"
    ]
  },
  "repository": {
    "type": "string",
    "required": true
  },
  "filter": {
    "type": "dict",
    "required": false,
    "default": {},
    "nullable": true
  },
  "payload": {
    "type": "dict",
    "required": false,
    "default": {},
    "nullable": true,
    "dependencies": [
      "operation"
    ]
  }
}